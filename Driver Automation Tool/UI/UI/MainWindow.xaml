                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="2." FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentColor}"/>
