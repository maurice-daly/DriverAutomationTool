<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Driver Automation Tool"
    Width="1200" Height="780"
    MinWidth="1000" MinHeight="650"
    WindowStartupLocation="CenterScreen"
    Background="Transparent"
    Foreground="{DynamicResource WindowForeground}"
    WindowStyle="None"
    AllowsTransparency="True"
    ResizeMode="CanResizeWithGrip"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True">

    <Window.Resources>
        <!-- Corner radius constants -->
        <CornerRadius x:Key="CardRadius">12</CornerRadius>
        <CornerRadius x:Key="ButtonRadius">8</CornerRadius>
        <CornerRadius x:Key="InputRadius">8</CornerRadius>
        <CornerRadius x:Key="WindowRadius">16</CornerRadius>

        <!-- Rounded Button Style -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource ButtonPrimary}"
                                CornerRadius="{StaticResource ButtonRadius}"
                                Padding="16,8"
                                BorderThickness="0"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonPrimaryHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource ButtonPrimaryForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource ButtonSecondary}"
                                CornerRadius="{StaticResource ButtonRadius}"
                                Padding="16,8"
                                BorderThickness="0"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonSecondaryHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource ButtonSecondaryForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Chevron Toggle Button (for collapsible panels) -->
        <Style x:Key="ChevronToggleButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource ButtonSecondary}"
                                CornerRadius="4"
                                Padding="0"
                                BorderThickness="0"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonSecondaryHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource ButtonSecondaryForeground}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource ButtonDanger}"
                                CornerRadius="{StaticResource ButtonRadius}"
                                Padding="16,8"
                                BorderThickness="0"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonDangerHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource ButtonPrimaryForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Warning Button -->
        <Style x:Key="WarningButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource StatusWarning}"
                                CornerRadius="{StaticResource ButtonRadius}"
                                Padding="16,8"
                                BorderThickness="0"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#1E293B"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Rounded TextBox -->
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{DynamicResource InputBackground}"
                                CornerRadius="{StaticResource InputRadius}"
                                BorderBrush="{DynamicResource InputBorder}"
                                BorderThickness="1"
                                Padding="10,8">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                <!-- Placeholder: visible only when TextBox is empty and unfocused -->
                                <TextBlock x:Name="placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="{DynamicResource InputPlaceholder}"
                                           FontSize="13"
                                           FontFamily="Segoe UI"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center"
                                           Margin="2,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Text}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="{DynamicResource InputForeground}"/>
        </Style>

        <Style x:Key="RoundedPasswordBox" TargetType="PasswordBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{DynamicResource InputBackground}"
                                CornerRadius="{StaticResource InputRadius}"
                                BorderBrush="{DynamicResource InputBorder}"
                                BorderThickness="1"
                                Padding="10,8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource InputForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="{DynamicResource InputForeground}"/>
        </Style>

        <!-- Pill ComboBox Toggle Button -->
        <ControlTemplate x:Key="PillComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="border"
                    Background="{DynamicResource ComboBackground}"
                    BorderBrush="{DynamicResource ComboBorder}"
                    BorderThickness="1"
                    CornerRadius="17"
                    Padding="14,0,10,0"
                    Cursor="Hand"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                    <Path x:Name="arrow" Grid.Column="1"
                          Data="M0,0 L4,4 L8,0"
                          Stroke="{DynamicResource ComboForeground}"
                          StrokeThickness="1.5"
                          VerticalAlignment="Center"
                          Margin="8,1,4,0"
                          StrokeLineJoin="Round"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ButtonPrimary}"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ButtonPrimary}"/>
                    <Setter TargetName="arrow" Property="RenderTransform">
                        <Setter.Value>
                            <RotateTransform Angle="180" CenterX="4" CenterY="2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Pill ComboBox Style (default for all ComboBox) -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource ComboForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource PillComboBoxToggleButton}"
                                          Focusable="False"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="16,0,28,0"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   VerticalOffset="4">
                                <Border x:Name="DropDownBorder"
                                        Background="{DynamicResource ComboBackground}"
                                        BorderBrush="{DynamicResource ComboBorder}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ComboForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="itemBorder"
                                Background="Transparent"
                                CornerRadius="8"
                                Padding="12,7"
                                Margin="0,1"
                                Cursor="Hand">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource SidebarHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="{DynamicResource ButtonPrimary}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ButtonPrimaryForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="checkBorder" Grid.Column="0"
                                    Width="18" Height="18"
                                    CornerRadius="5"
                                    Background="{DynamicResource SidebarActive}"
                                    BorderBrush="{DynamicResource CheckBorder}"
                                    BorderThickness="1.5"
                                    VerticalAlignment="Center"
                                    SnapsToDevicePixels="True">
                                <Path x:Name="checkMark"
                                      Data="M3,7 L7,11 L13,3"
                                      Stroke="{DynamicResource ButtonPrimaryForeground}"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Stretch="Uniform"
                                      Width="10" Height="10"
                                      Visibility="Collapsed"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBorder" Property="Background" Value="{DynamicResource ButtonPrimary}"/>
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource ButtonPrimary}"/>
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBorder" Property="BorderBrush" Value="{DynamicResource ButtonPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="checkBorder" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid CheckBox Style (inherits Modern CheckBox, adds centering) -->
        <Style x:Key="DataGridCheckBox" TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
        </Style>

        <!-- Toggle Switch Style -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="switchTrack" Grid.Column="0"
                                    Width="40" Height="20"
                                    CornerRadius="10"
                                    Background="{DynamicResource InputBackground}"
                                    BorderBrush="{DynamicResource ComboBorder}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    SnapsToDevicePixels="True">
                                <Border x:Name="switchThumb"
                                        Width="16" Height="16"
                                        CornerRadius="8"
                                        Background="{DynamicResource InputPlaceholder}"
                                        HorizontalAlignment="Left"
                                        Margin="2,0,0,0"
                                        VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="10,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="switchTrack" Property="Background" Value="{DynamicResource ButtonPrimary}"/>
                                <Setter TargetName="switchThumb" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="switchThumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="switchThumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="switchTrack" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="switchTrack" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Window Control Button (icon-only, uses Segoe MDL2 Assets) -->
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                CornerRadius="4"
                                Cursor="Hand"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SidebarHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        </Style>

        <!-- Close Button (red hover) -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                CornerRadius="4"
                                Cursor="Hand"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonDanger}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ButtonPrimaryForeground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Navigation Button -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                CornerRadius="{StaticResource ButtonRadius}"
                                Padding="14,10"
                                Margin="4,1"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SidebarHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- Active Nav Button -->
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource SidebarActive}"
                                CornerRadius="{StaticResource ButtonRadius}"
                                Padding="14,10"
                                Margin="4,1"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Sub-Navigation Button (indented, smaller) -->
        <Style x:Key="SubNavButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="Transparent"
                                CornerRadius="{StaticResource ButtonRadius}"
                                Padding="14,8"
                                Margin="20,1,4,1"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SidebarHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- Active Sub-Navigation Button -->
        <Style x:Key="SubNavButtonActive" TargetType="Button" BasedOn="{StaticResource SubNavButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{DynamicResource SidebarActive}"
                                CornerRadius="{StaticResource ButtonRadius}"
                                Padding="14,8"
                                Margin="20,1,4,1"
                                Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Card Border -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource CardRadius}"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- DataGrid Style -->
        <!-- DataGrid Column Header Style -->
        <Style x:Key="ModernColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SidebarActive}"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SidebarBackground}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <Path x:Name="SortArrow" Grid.Column="1"
                                      VerticalAlignment="Center" Margin="6,0,2,0"
                                      Fill="{DynamicResource SidebarForeground}"
                                      Visibility="Collapsed"
                                      RenderTransformOrigin="0.5,0.5"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="Data" Value="M 0 4 L 3.5 0 L 7 4 Z"/>
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="SortArrow" Property="Data" Value="M 0 0 L 3.5 4 L 7 0 Z"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SidebarHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Row Style -->
        <Style x:Key="ModernDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{DynamicResource GridAlternate}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SidebarHover}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource GridSelection}"/>
                    <Setter Property="Foreground" Value="{DynamicResource GridSelectionForeground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid Cell Style -->
        <Style x:Key="ModernDataGridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource GridSelectionForeground}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SidebarActive}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <Setter Property="RowHeight" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource ModernColumnHeader}"/>
            <Setter Property="RowStyle" Value="{StaticResource ModernDataGridRow}"/>
            <Setter Property="CellStyle" Value="{StaticResource ModernDataGridCell}"/>
            <Setter Property="RowBackground" Value="{DynamicResource SidebarBackground}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridAlternate}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource SidebarActive}"/>
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True"/>
        </Style>

        <!-- Status label -->
        <Style x:Key="StatusLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WindowForeground}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WindowForeground}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Thin Themed ScrollBar Thumb -->
        <Style x:Key="ThinScrollThumb" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumbBorder"
                                CornerRadius="5"
                                Background="{DynamicResource ScrollThumb}"
                                Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="{DynamicResource ScrollThumbHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar Track Button (invisible) -->
        <Style x:Key="ScrollBarTrackButton" TargetType="RepeatButton">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Vertical ScrollBar -->
        <ControlTemplate x:Key="VerticalScrollBar" TargetType="ScrollBar">
            <Border Background="{DynamicResource ScrollTrack}"
                    CornerRadius="5" Width="10">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}" Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ThinScrollThumb}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}" Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <!-- Wide Vertical ScrollBar (18px) -->
        <ControlTemplate x:Key="WideVerticalScrollBar" TargetType="ScrollBar">
            <Border Background="{DynamicResource ScrollTrack}"
                    CornerRadius="5" Width="18">
                <Track x:Name="PART_Track" IsDirectionReversed="True">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}" Command="ScrollBar.PageUpCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ThinScrollThumb}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}" Command="ScrollBar.PageDownCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <!-- Horizontal ScrollBar -->
        <ControlTemplate x:Key="HorizontalScrollBar" TargetType="ScrollBar">
            <Border Background="{DynamicResource ScrollTrack}"
                    CornerRadius="5" Height="10">
                <Track x:Name="PART_Track" IsDirectionReversed="False">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}" Command="ScrollBar.PageLeftCommand"/>
                    </Track.DecreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb Style="{StaticResource ThinScrollThumb}"/>
                    </Track.Thumb>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Style="{StaticResource ScrollBarTrackButton}" Command="ScrollBar.PageRightCommand"/>
                    </Track.IncreaseRepeatButton>
                </Track>
            </Border>
        </ControlTemplate>

        <!-- Default ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="6"/>
                    <Setter Property="Height" Value="Auto"/>
                    <Setter Property="Template" Value="{StaticResource VerticalScrollBar}"/>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="6"/>
                    <Setter Property="Template" Value="{StaticResource HorizontalScrollBar}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Main Window Border with rounded corners -->
    <Border CornerRadius="{StaticResource WindowRadius}"
            Background="{DynamicResource WindowBackground}"
            BorderBrush="{DynamicResource WindowBorder}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SidebarBackground}"
                    CornerRadius="16,16,0,0"
                    x:Name="TitleBar">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="&#xE799;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{DynamicResource AccentColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Driver Automation Tool" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WindowForeground}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txt_Version" Text=" Version 10.0.15" FontSize="11"
                                   Foreground="{DynamicResource InputPlaceholder}" VerticalAlignment="Center" Margin="4,0"/>
                    </StackPanel>

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="btn_ThemeToggle" Content="&#xE793;"
                                Style="{StaticResource WindowControlButton}" Width="36" Height="28"
                                FontSize="12" ToolTip="Toggle Theme"/>
                        <Button x:Name="btn_TitleBarCoffee"
                                Style="{StaticResource WindowControlButton}" Width="36" Height="28"
                                FontSize="13" ToolTip="Buy Me a Coffee"
                                Content="&#xE006;"/>
                        <Button x:Name="btn_Minimize" Content="&#xE949;"
                                Style="{StaticResource WindowControlButton}" Width="36" Height="28"/>
                        <Button x:Name="btn_Maximize" Content="&#xE739;"
                                Style="{StaticResource WindowControlButton}" Width="36" Height="28"/>
                        <Button x:Name="btn_Close" Content="&#xE106;"
                                Style="{StaticResource CloseButton}" Width="36" Height="28"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}"
                        CornerRadius="0,0,0,16">
                    <DockPanel>
                        <!-- Logo Area -->
                        <Border DockPanel.Dock="Top" Padding="16,16,16,8">
                            <StackPanel>
                                <Image x:Name="img_Logo" Height="120" HorizontalAlignment="Center" Margin="0,0,0,16" Stretch="Uniform"/>
                                <TextBlock Text="Driver Automation Tool" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource WindowForeground}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <Border Height="1" Background="{DynamicResource WindowBorder}" Margin="0,4"/>
                            </StackPanel>
                        </Border>

                        <!-- Navigation -->
                        <ScrollViewer DockPanel.Dock="Top"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0">
                        <StackPanel Margin="8,8,8,0">
                            <TextBlock Text="MAIN" FontSize="10" FontWeight="Bold" Margin="16,0,0,6"
                                       Foreground="{DynamicResource InputPlaceholder}"/>
                            <Button x:Name="nav_ModelSelection"
                                    Style="{StaticResource NavButtonActive}">
                                <TextBlock><Run Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Model Selection"/></TextBlock>
                            </Button>
                            <Button x:Name="nav_CustomDriverPack"
                                    Style="{StaticResource NavButton}">
                                <TextBlock><Run Text="&#xE90F;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Custom Driver Pack"/></TextBlock>
                            </Button>

                            <TextBlock Text="CONFIGURATION" FontSize="10" FontWeight="Bold" Margin="16,16,0,6"
                                       Foreground="{DynamicResource InputPlaceholder}"/>
                            <Button x:Name="nav_ConfigMgr"
                                    Style="{StaticResource NavButton}">
                                <TextBlock><Run Text="&#xE912;" FontFamily="Segoe MDL2 Assets"/><Run Text="  ConfigMgr Settings"/></TextBlock>
                            </Button>
                            <StackPanel x:Name="panel_ConfigMgrSub" Visibility="Collapsed">
                                <Button x:Name="nav_ConfigMgrEnvironment"
                                        Style="{StaticResource SubNavButton}">
                                    <TextBlock><Run Text="&#xE968;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Environment"/></TextBlock>
                                </Button>
                                <Button x:Name="nav_Packages"
                                        Style="{StaticResource SubNavButton}">
                                    <TextBlock><Run Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Package Management"/></TextBlock>
                                </Button>
                                <Button x:Name="nav_Distribution"
                                        Style="{StaticResource SubNavButton}">
                                    <TextBlock><Run Text="&#xE753;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Distribution Points"/></TextBlock>
                                </Button>
                            </StackPanel>
                            <Button x:Name="nav_IntuneSettings"
                                    Style="{StaticResource NavButton}">
                                <TextBlock><Run Text="&#xE774;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Intune Settings"/></TextBlock>
                            </Button>
                            <StackPanel x:Name="panel_IntuneSub" Visibility="Collapsed">
                                <Button x:Name="nav_IntuneAuth"
                                        Style="{StaticResource SubNavButton}">
                                    <TextBlock><Run Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Environment"/></TextBlock>
                                </Button>
                                <Button x:Name="nav_IntuneOptions"
                                        Style="{StaticResource SubNavButton}">
                                    <TextBlock><Run Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Package Options"/></TextBlock>
                                </Button>
                                <Button x:Name="nav_IntunePackageMgmt"
                                        Style="{StaticResource SubNavButton}">
                                    <TextBlock><Run Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Package Management"/></TextBlock>
                                </Button>
                                <Button x:Name="nav_BIOSSecurity"
                                        Style="{StaticResource SubNavButton}">
                                    <TextBlock><Run Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"/><Run Text="  BIOS Security"/></TextBlock>
                                </Button>
                            </StackPanel>
                            <Button x:Name="nav_CommonSettings"
                                    Style="{StaticResource NavButton}">
                                <TextBlock><Run Text="&#xE713;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Common Settings"/></TextBlock>
                            </Button>

                            <TextBlock Text="TOOLS" FontSize="10" FontWeight="Bold" Margin="16,16,0,6"
                                       Foreground="{DynamicResource InputPlaceholder}"/>
                            <Button x:Name="nav_Log"
                                    Style="{StaticResource NavButton}">
                                <TextBlock><Run Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Logs"/></TextBlock>
                            </Button>
                            <Button x:Name="nav_ModernMgmt"
                                    Style="{StaticResource NavButton}">
                                <TextBlock><Run Text="&#xECAD;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Modern Driver Mgmt"/></TextBlock>
                            </Button>
                            <Button x:Name="nav_About"
                                    Style="{StaticResource NavButton}">
                                <TextBlock><Run Text="&#xE946;" FontFamily="Segoe MDL2 Assets"/><Run Text="  About"/></TextBlock>
                            </Button>
                        </StackPanel>
                        </ScrollViewer>

                        <!-- Footer -->
                        <Border DockPanel.Dock="Bottom" Padding="16,8,16,12" VerticalAlignment="Bottom">
                            <StackPanel>
                                <Border Height="1" Background="{DynamicResource WindowBorder}" Margin="0,0,0,8"/>
                                <TextBlock Text="Created by Maurice Daly" FontSize="10"
                                           Foreground="{DynamicResource InputPlaceholder}"/>
                            </StackPanel>
                        </Border>
                    </DockPanel>
                </Border>

                <!-- Content Area -->
                <Border Grid.Column="1" CornerRadius="0,0,16,0" Padding="24,20">
                    <Grid>
                        <!-- View: Model Selection (Default View) -->
                        <Grid x:Name="view_ModelSelection" Visibility="Visible">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}">
                                <Run Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="20"/><Run Text="  Model Selection"/>
                            </TextBlock>

                            <!-- Filter Bar -->
                            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 1: Labels -->
                                    <TextBlock Grid.Column="0" Grid.Row="0" Text="OEM" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,8,4" Padding="4,0,0,0"/>
                                    <TextBlock Grid.Column="1" Grid.Row="0" Text="Operating System" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource InputPlaceholder}" Margin="8,0,8,4" Padding="4,0,0,0"/>
                                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Architecture" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource InputPlaceholder}" Margin="8,0,8,4" Padding="4,0,0,0"/>
                                    <TextBlock Grid.Column="3" Grid.Row="0" Text="Platform" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource InputPlaceholder}" Margin="8,0,8,4" Padding="4,0,0,0"/>
                                    <TextBlock Grid.Column="4" Grid.Row="0" Text="Package Type" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource InputPlaceholder}" Margin="8,0,0,4" Padding="4,0,0,0"/>

                                    <!-- Row 2: Controls -->
                                    <!-- OEM Multi-Select Pill Dropdown -->
                                    <Border Grid.Column="0" Grid.Row="1" Margin="0,0,8,0" VerticalAlignment="Top">
                                        <Grid>
                                            <ToggleButton x:Name="btn_OEMToggle"
                                                          Template="{StaticResource PillComboBoxToggleButton}"
                                                          Height="34"
                                                          Focusable="False"
                                                          ClickMode="Press">
                                                <TextBlock x:Name="txt_OEMDisplay" Text="Select OEMs..."
                                                           Foreground="{DynamicResource ComboForeground}"
                                                           FontSize="13" FontFamily="Segoe UI"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </ToggleButton>
                                            <Popup x:Name="popup_OEM"
                                                   PlacementTarget="{Binding ElementName=btn_OEMToggle}"
                                                   Placement="Bottom"
                                                   IsOpen="{Binding IsChecked, ElementName=btn_OEMToggle, Mode=TwoWay}"
                                                   AllowsTransparency="True"
                                                   StaysOpen="False"
                                                   PopupAnimation="Slide"
                                                   VerticalOffset="4">
                                                <Border Background="{DynamicResource ComboBackground}"
                                                        BorderBrush="{DynamicResource ComboBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="4"
                                                        MinWidth="{Binding ActualWidth, ElementName=btn_OEMToggle}">
                                                    <StackPanel>
                                                        <Border x:Name="border_OEM_Acer" Background="Transparent" CornerRadius="8" Padding="12,7" Margin="0,1" Cursor="Hand">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource SidebarHover}"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <CheckBox x:Name="chk_OEM_Acer" Content="Acer" Margin="0"/>
                                                        </Border>
                                                        <Border x:Name="border_OEM_Dell" Background="Transparent" CornerRadius="8" Padding="12,7" Margin="0,1" Cursor="Hand">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource SidebarHover}"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <CheckBox x:Name="chk_OEM_Dell" Content="Dell" Margin="0"/>
                                                        </Border>
                                                        <Border x:Name="border_OEM_HP" Background="Transparent" CornerRadius="8" Padding="12,7" Margin="0,1" Cursor="Hand">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource SidebarHover}"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <CheckBox x:Name="chk_OEM_HP" Content="HP" Margin="0"/>
                                                        </Border>
                                                        <Border x:Name="border_OEM_Lenovo" Background="Transparent" CornerRadius="8" Padding="12,7" Margin="0,1" Cursor="Hand">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource SidebarHover}"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <CheckBox x:Name="chk_OEM_Lenovo" Content="Lenovo" Margin="0"/>
                                                        </Border>
                                                        <Border x:Name="border_OEM_Microsoft" Background="Transparent" CornerRadius="8" Padding="12,7" Margin="0,1" Cursor="Hand">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource SidebarHover}"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <CheckBox x:Name="chk_OEM_Microsoft" Content="Microsoft" Margin="0"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Border>
                                    <ComboBox x:Name="cmb_OS" Grid.Column="1" Grid.Row="1" Margin="8,0,8,0"
                                              VerticalAlignment="Top" Height="34">
                                        <ComboBoxItem Content="Windows 11 25H2" IsSelected="True"/>
                                        <ComboBoxItem Content="Windows 11 24H2"/>
                                        <ComboBoxItem Content="Windows 11 23H2"/>
                                        <ComboBoxItem Content="Windows 11 22H2"/>
                                    </ComboBox>
                                    <ComboBox x:Name="cmb_Architecture" Grid.Column="2" Grid.Row="1" Margin="8,0,8,0"
                                              VerticalAlignment="Top" Height="34">
                                        <ComboBoxItem Content="x64" IsSelected="True"/>
                                        <ComboBoxItem Content="Arm64"/>
                                    </ComboBox>
                                    <ComboBox x:Name="cmb_Platform" Grid.Column="3" Grid.Row="1" Margin="8,0,8,0"
                                              VerticalAlignment="Top" Height="34">
                                        <ComboBoxItem Content="Configuration Manager" IsSelected="True"/>
                                        <ComboBoxItem Content="Intune"/>
                                        <ComboBoxItem Content="WIM Package Only"/>
                                        <ComboBoxItem Content="Download Only"/>
                                    </ComboBox>
                                    <ComboBox x:Name="cmb_PackageType" Grid.Column="4" Grid.Row="1" Margin="8,0,0,0"
                                              VerticalAlignment="Top" Height="34">
                                        <ComboBoxItem Content="Drivers" IsSelected="True"/>
                                        <ComboBoxItem Content="BIOS"/>
                                        <ComboBoxItem Content="All"/>
                                    </ComboBox>
                                    <Button x:Name="btn_RefreshModels" Grid.Column="5" Grid.Row="1"
                                            Style="{StaticResource SecondaryButton}"
                                            VerticalAlignment="Top" Margin="12,0,0,0" Height="34">
                                        <TextBlock><Run Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Refresh"/></TextBlock>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Model Grid -->
                            <Border Grid.Row="2" Style="{StaticResource CardPanel}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Search and Select Controls -->
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="325"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txt_ModelSearch" Grid.Column="0"
                                                 Style="{StaticResource RoundedTextBox}"
                                                 Tag="Type to search for a model"
                                                 Height="34" Margin="0,0,8,0"/>
                                        <TextBlock x:Name="txt_ModelCount" Grid.Column="1"
                                                   Style="{StaticResource StatusLabel}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,0,8,0"/>
                                        <Button x:Name="btn_SelectAll" Grid.Column="2"
                                                Style="{StaticResource SecondaryButton}"
                                                Height="34" Margin="0,0,4,0">
                                            <TextBlock><Run Text="&#xE8B3;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Select All"/></TextBlock>
                                        </Button>
                                        <Button x:Name="btn_DeselectAll" Grid.Column="3"
                                                Style="{StaticResource SecondaryButton}"
                                                Height="34" Margin="0,0,0,0">
                                            <TextBlock><Run Text="&#xE8E6;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Deselect All"/></TextBlock>
                                        </Button>
                                    </Grid>

                                    <!-- DataGrid -->
                                    <Border Grid.Row="1" CornerRadius="10"
                                            BorderBrush="{DynamicResource SidebarActive}"
                                            BorderThickness="1"
                                            Background="{DynamicResource SidebarBackground}"
                                            ClipToBounds="True">
                                        <DataGrid x:Name="grid_Models"
                                                  Style="{StaticResource ModernDataGrid}"
                                                  BorderThickness="0">
                                            <DataGrid.ContextMenu>
                                                <ContextMenu x:Name="ctx_ModelMenu"
                                                             HasDropShadow="True"
                                                             Padding="0">
                                                    <ContextMenu.Template>
                                                        <ControlTemplate TargetType="ContextMenu">
                                                            <Border Background="{DynamicResource CardBackground}"
                                                                    BorderBrush="{DynamicResource CardBorder}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="4,6"
                                                                    SnapsToDevicePixels="True">
                                                                <Border.Effect>
                                                                    <DropShadowEffect BlurRadius="16" Opacity="0.35" ShadowDepth="4" Color="Black"/>
                                                                </Border.Effect>
                                                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </ContextMenu.Template>
                                                    <ContextMenu.Resources>
                                                        <!-- Styled MenuItem template matching app theme -->
                                                        <Style TargetType="MenuItem">
                                                            <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
                                                            <Setter Property="FontFamily" Value="Segoe UI"/>
                                                            <Setter Property="FontSize" Value="12"/>
                                                            <Setter Property="Padding" Value="12,8"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="MenuItem">
                                                                        <Border x:Name="MenuItemBorder"
                                                                                Background="Transparent"
                                                                                Padding="{TemplateBinding Padding}"
                                                                                CornerRadius="4"
                                                                                Margin="2,1">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <ContentPresenter Grid.Column="0"
                                                                                                  Content="{TemplateBinding Icon}"
                                                                                                  VerticalAlignment="Center"
                                                                                                  Margin="0,0,10,0"/>
                                                                                <ContentPresenter Grid.Column="1"
                                                                                                  ContentSource="Header"
                                                                                                  VerticalAlignment="Center"/>
                                                                            </Grid>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsHighlighted" Value="True">
                                                                                <Setter TargetName="MenuItemBorder" Property="Background"
                                                                                        Value="{DynamicResource SidebarHover}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsEnabled" Value="False">
                                                                                <Setter Property="Opacity" Value="0.4"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                        <!-- Themed Separator -->
                                                        <Style TargetType="Separator">
                                                            <Setter Property="Background" Value="{DynamicResource CardBorder}"/>
                                                            <Setter Property="Margin" Value="8,4"/>
                                                            <Setter Property="Height" Value="1"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Separator">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                                Height="{TemplateBinding Height}"
                                                                                Margin="{TemplateBinding Margin}"
                                                                                SnapsToDevicePixels="True"/>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ContextMenu.Resources>

                                                    <!-- Header: DAT logo + "Package Options" -->
                                                    <MenuItem IsHitTestVisible="False" IsEnabled="False" Padding="10,8">
                                                        <MenuItem.Template>
                                                            <ControlTemplate>
                                                                <StackPanel Orientation="Horizontal" Margin="10,4,10,2">
                                                                    <Image x:Name="ctx_HeaderLogo"
                                                                           Width="20" Height="20"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,8,0"
                                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                    <TextBlock Text="Package Options"
                                                                               FontFamily="Segoe UI"
                                                                               FontSize="13"
                                                                               FontWeight="Bold"
                                                                               Foreground="{DynamicResource SidebarForeground}"
                                                                               VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </ControlTemplate>
                                                        </MenuItem.Template>
                                                    </MenuItem>

                                                    <!-- Divider -->
                                                    <Separator/>

                                                    <!-- Menu items -->
                                                    <MenuItem x:Name="ctx_AddCustomDrivers" Header="Add Custom Drivers">
                                                        <MenuItem.Icon>
                                                            <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                       Foreground="{DynamicResource AccentColor}"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                    <MenuItem x:Name="ctx_ClearCustomDrivers" Header="Clear Custom Drivers">
                                                        <MenuItem.Icon>
                                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                       Foreground="{DynamicResource StatusWarning}"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>

                                                    <Separator/>

                                                    <MenuItem x:Name="ctx_ForcePackageUpdate" Header="Force Existing Package Update">
                                                        <MenuItem.Icon>
                                                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                       Foreground="{DynamicResource AccentColor}"/>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </DataGrid.ContextMenu>
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="&#x2611;" Width="40" SortMemberPath="Selected">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <!-- IsHitTestVisible=False + Focusable=False make this CheckBox
                                                                 purely visual. All toggling goes through the PreviewMouseLeftButtonDown
                                                                 / PreviewKeyDown handlers which set item.Selected directly.
                                                                 Because ModelItem implements INPC, the TwoWay binding updates
                                                                 the visual automatically — no manual tree-walking needed.
                                                                 TwoWay is used (not OneWay) so the binding engine tracks the
                                                                 property correctly via INPC; user write-back is impossible
                                                                 because IsHitTestVisible=False means no user interaction reaches
                                                                 the CheckBox. -->
                                                            <CheckBox IsChecked="{Binding Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      IsHitTestVisible="False"
                                                                      Focusable="False"
                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="OEM" Width="100"
                                                                    Binding="{Binding OEM}" IsReadOnly="True"
                                                                    SortMemberPath="OEM"/>
                                                <DataGridTextColumn Header="Model" Width="*"
                                                                    Binding="{Binding Model}" IsReadOnly="True"
                                                                    SortMemberPath="Model"/>
                                                <DataGridTextColumn Header="OS" Width="120"
                                                                    Binding="{Binding OS}" IsReadOnly="True"
                                                                    SortMemberPath="OS"/>
                                                <DataGridTextColumn Header="Build" Width="80"
                                                                    Binding="{Binding Build}" IsReadOnly="True"
                                                                    SortMemberPath="Build"/>
                                                <DataGridTextColumn Header="Baseboards" Width="140"
                                                                    Binding="{Binding Baseboards}" IsReadOnly="True"
                                                                    SortMemberPath="Baseboards"/>
                                                <DataGridTextColumn Header="Driver" Width="80"
                                                                    Binding="{Binding Version}" IsReadOnly="True"
                                                                    SortMemberPath="Version"/>
                                                <DataGridTextColumn Header="BIOS" Width="80"
                                                                    Binding="{Binding BIOSVersion}" IsReadOnly="True"
                                                                    SortMemberPath="BIOSVersion"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Model Detail Panel -->
                            <Border x:Name="panel_ModelDetail" Grid.Row="3" Style="{StaticResource CardPanel}" Margin="0,8,0,0"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,10">
                                        <Run Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Package Details"/>
                                    </TextBlock>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- OEM & Model -->
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="OEM" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="txt_ModelDetail_OEM"
                                                       FontSize="11" Foreground="{DynamicResource WindowForeground}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="MODEL" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,10,0,4"/>
                                            <TextBlock x:Name="txt_ModelDetail_Model"
                                                       FontSize="11" Foreground="{DynamicResource WindowForeground}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- OS & Build -->
                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Text="OPERATING SYSTEM" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="txt_ModelDetail_OS"
                                                       FontSize="11" Foreground="{DynamicResource WindowForeground}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="BUILD" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,10,0,4"/>
                                            <TextBlock x:Name="txt_ModelDetail_Build"
                                                       FontSize="11" Foreground="{DynamicResource WindowForeground}"/>
                                        </StackPanel>

                                        <!-- Baseboards & Versions -->
                                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                            <TextBlock Text="BASEBOARDS" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="txt_ModelDetail_Baseboards"
                                                       FontSize="11" FontFamily="Consolas"
                                                       Foreground="{DynamicResource AccentColorLight}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="DRIVER VERSION" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,10,0,4"/>
                                            <TextBlock x:Name="txt_ModelDetail_Version"
                                                       FontSize="11" Foreground="{DynamicResource WindowForeground}"/>
                                            <TextBlock Text="BIOS VERSION" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,10,0,4"/>
                                            <TextBlock x:Name="txt_ModelDetail_BIOS"
                                                       FontSize="11" Foreground="{DynamicResource WindowForeground}"/>
                                        </StackPanel>

                                        <!-- NVIDIA & Custom Drivers -->
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Text="NVIDIA GFX" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4"/>
                                            <TextBlock x:Name="txt_ModelDetail_GFX"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Text="CUSTOM DRIVERS" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,10,0,4"/>
                                            <TextBlock x:Name="txt_ModelDetail_CustomPath"
                                                       FontSize="11" FontFamily="Consolas"
                                                       Foreground="{DynamicResource WindowForeground}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Build Progress Panel (shown during build) -->
                            <Border x:Name="panel_BuildProgress" Grid.Row="4" Style="{StaticResource CardPanel}" Margin="0,8,0,0" Visibility="Collapsed">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: Counters -->
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Current:" FontSize="12" Foreground="{DynamicResource InputPlaceholder}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock x:Name="txt_BuildCurrentJob" Grid.Column="1" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource StatusSuccess}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="Remaining:" FontSize="12" Foreground="{DynamicResource InputPlaceholder}" VerticalAlignment="Center" Margin="16,0,6,0"/>
                                        <TextBlock x:Name="txt_BuildRemaining" Grid.Column="4" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource StatusSuccess}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="6" Text="File Size:" FontSize="12" Foreground="{DynamicResource InputPlaceholder}" VerticalAlignment="Center" Margin="16,0,6,0"/>
                                        <TextBlock x:Name="txt_BuildFileSize" Grid.Column="7" Text="---" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource StatusSuccess}" VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Row 1: Download progress bar -->
                                    <Grid Grid.Row="1" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="txt_BuildProgressLabel" Grid.Column="0" Text="Download:" FontSize="11" Foreground="{DynamicResource InputPlaceholder}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ProgressBar x:Name="progress_Download" Grid.Column="1" Height="8"
                                                     Background="{DynamicResource ProgressBackground}"
                                                     Foreground="{DynamicResource ProgressForeground}"
                                                     Minimum="0" Maximum="100" Value="0"/>
                                        <TextBlock x:Name="txt_BuildDownloadPercent" Grid.Column="2" Text="0%" FontSize="11" Foreground="{DynamicResource InputPlaceholder}" VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="35"/>
                                        <TextBlock x:Name="txt_BuildDownloadSpeed" Grid.Column="3" Text="" FontSize="11" Foreground="{DynamicResource InputPlaceholder}" VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="70"/>
                                    </Grid>

                                    <!-- Row 2: Job status message -->
                                    <TextBlock x:Name="txt_BuildJobStatus" Grid.Row="2" Text="" FontSize="12"
                                               Foreground="{DynamicResource StatusSuccess}" TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis" MaxHeight="40"/>
                                </Grid>
                            </Border>

                            <!-- Bottom Action Bar -->
                            <Border Grid.Row="5" Margin="0,12,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Status -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                        <ProgressBar x:Name="progress_Job" Width="200" Height="6"
                                                     Background="{DynamicResource ProgressBackground}"
                                                     Foreground="{DynamicResource ProgressForeground}"
                                                     Visibility="Collapsed" Margin="0,0,12,0"/>
                                        <!-- Job status pill -->
                                        <Border x:Name="pill_BuildStatus" Visibility="Collapsed"
                                                CornerRadius="10" Padding="10,4" Margin="0,0,10,0"
                                                VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="txt_BuildStatusIcon" FontSize="11" FontWeight="SemiBold"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="txt_BuildStatusText" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#FFFFFF" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <TextBlock x:Name="txt_Status" Style="{StaticResource StatusLabel}"
                                                   VerticalAlignment="Center"/>
                                        <!-- Elapsed time -->
                                        <TextBlock x:Name="txt_BuildElapsed" FontSize="11"
                                                   Foreground="{DynamicResource InputPlaceholder}"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>

                                    <!-- Action Buttons -->
                                    <Button x:Name="btn_Abort" Grid.Column="1"
                                            Style="{StaticResource DangerButton}"
                                            IsEnabled="False" Margin="0,0,8,0" Height="36">
                                        <TextBlock><Run Text="&#xE711;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Abort"/></TextBlock>
                                    </Button>
                                    <Button x:Name="btn_Build" Grid.Column="2"
                                            Style="{StaticResource RoundedButton}"
                                            IsEnabled="False" Height="36">
                                        <TextBlock><Run Text="&#xE768;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Build Package"/></TextBlock>
                                    </Button>
                                    <Button x:Name="btn_Schedule" Grid.Column="3"
                                            Style="{StaticResource SecondaryButton}"
                                            IsEnabled="False" Margin="8,0,0,0" Height="36">
                                        <TextBlock><Run Text="&#xE787;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Schedule"/></TextBlock>
                                    </Button>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- View: Package Management -->
                        <Grid x:Name="view_Packages" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="2*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}">
                                <Run Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="20"/><Run Text="  Package Management"/>
                            </TextBlock>

                            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Package Type" FontSize="11"
                                               Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,8,4"/>
                                    <TextBlock Grid.Column="1" Grid.Row="0" Text="Deployment State" FontSize="11"
                                               Foreground="{DynamicResource InputPlaceholder}" Margin="8,0,8,4"/>
                                    <TextBlock Grid.Column="2" Grid.Row="0" Text="Action" FontSize="11"
                                               Foreground="{DynamicResource InputPlaceholder}" Margin="8,0,8,4"/>

                                    <ComboBox x:Name="cmb_PkgPackageType" Grid.Column="0" Grid.Row="1" Margin="0,0,8,0" Height="34">
                                        <ComboBoxItem Content="Drivers" IsSelected="True"/>
                                        <ComboBoxItem Content="BIOS Update"/>
                                    </ComboBox>
                                    <ComboBox x:Name="cmb_DeploymentState" Grid.Column="1" Grid.Row="1" Margin="8,0,8,0" Height="34">
                                        <ComboBoxItem Content="Production" IsSelected="True"/>
                                        <ComboBoxItem Content="Pilot"/>
                                        <ComboBoxItem Content="Retired"/>
                                    </ComboBox>
                                    <ComboBox x:Name="cmb_PkgAction" Grid.Column="2" Grid.Row="1" Margin="8,0,8,0"
                                              Height="34" Width="200">
                                        <ComboBoxItem Content="Move to Production"/>
                                        <ComboBoxItem Content="Move to Pilot"/>
                                        <ComboBoxItem Content="Move to Retired"/>
                                        <ComboBoxItem Content="Change OS Target"/>
                                    </ComboBox>
                                    <Button x:Name="btn_RefreshPkgs" Grid.Column="3" Grid.Row="1"
                                            Style="{StaticResource SecondaryButton}" Height="34" Margin="0,0,0,0">
                                        <TextBlock><Run Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Refresh"/></TextBlock>
                                    </Button>
                                </Grid>
                            </Border>

                            <TextBlock x:Name="txt_PkgStatus" Grid.Row="2" FontSize="12"
                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,8"
                                       Visibility="Collapsed"/>

                            <!-- Search bar + Select All/None + Delete -->
                            <Grid Grid.Row="3" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txt_CmPkgSearch" Grid.Column="0"
                                         Style="{StaticResource RoundedTextBox}"
                                         Tag="Enter text to search"
                                         Height="34" Margin="0,0,8,0"/>
                                <Button x:Name="btn_CmPkgSelectAll" Grid.Column="1"
                                        Style="{StaticResource SecondaryButton}" Height="34" Margin="0,0,4,0">
                                    <TextBlock><Run Text="&#xE73A;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Select All"/></TextBlock>
                                </Button>
                                <Button x:Name="btn_CmPkgSelectNone" Grid.Column="2"
                                        Style="{StaticResource SecondaryButton}" Height="34" Margin="0,0,4,0">
                                    <TextBlock><Run Text="&#xE739;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Select None"/></TextBlock>
                                </Button>
                                <Button x:Name="btn_CmDeleteSelected" Grid.Column="3"
                                        Style="{StaticResource DangerButton}" Height="34"
                                        IsEnabled="False">
                                    <TextBlock><Run Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Delete Selected"/></TextBlock>
                                </Button>
                            </Grid>

                            <Border Grid.Row="4" Style="{StaticResource CardPanel}">
                                <DataGrid x:Name="grid_Packages" Style="{StaticResource ModernDataGrid}">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="&#x2611;" Width="40" Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                ElementStyle="{StaticResource DataGridCheckBox}"
                                                                EditingElementStyle="{StaticResource DataGridCheckBox}"/>
                                        <DataGridTextColumn Header="Name" Width="*" Binding="{Binding Name}" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Version" Width="90" Binding="{Binding Version}" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Package ID" Width="95" Binding="{Binding PackageID}" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Source Date" Width="155" Binding="{Binding SourceDate}" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <!-- Package Details Panel -->
                            <Border x:Name="panel_PkgDetails" Grid.Row="5" Style="{StaticResource CardPanel}" Margin="0,12,0,0" Visibility="Collapsed">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WindowForeground}">
                                            <Run Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Package Details"/>
                                        </TextBlock>
                                        <Button x:Name="btn_CmReportIssue" Grid.Column="1"
                                                Style="{StaticResource WarningButton}" Height="30"
                                                IsEnabled="False">
                                            <TextBlock><Run Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Report Issue"/></TextBlock>
                                        </Button>
                                        <Button x:Name="btn_CmDeletePackage" Grid.Column="2"
                                                Style="{StaticResource DangerButton}" Height="30"
                                                Margin="8,0,0,0" IsEnabled="False">
                                            <TextBlock><Run Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Delete Package"/></TextBlock>
                                        </Button>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                            <TextBlock Text="Package Name" FontSize="11" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="txt_PkgDetailName" FontSize="13" Foreground="{DynamicResource WindowForeground}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                            <TextBlock Text="Description" FontSize="11" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="txt_PkgDetailDesc" FontSize="13" Foreground="{DynamicResource WindowForeground}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                            <TextBlock Text="Source Path" FontSize="11" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="txt_PkgDetailSource" FontSize="13" Foreground="{DynamicResource WindowForeground}" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                            <TextBlock Text="Manufacturer" FontSize="11" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="txt_PkgDetailMfr" FontSize="13" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,10"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
