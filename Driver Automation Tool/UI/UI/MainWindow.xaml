                                    <TextBlock Grid.Row="2" x:Name="txt_EulaWarning" FontSize="14" FontWeight="SemiBold"
                                               Foreground="#E8A035" Visibility="Collapsed" Margin="0,0,0,10">
                                        <Run Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"/><Run Text="  You must accept the EULA before building packages."/>
                                    </TextBlock>

