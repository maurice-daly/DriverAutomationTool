                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}">
                                <Run Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="20"/><Run Text="  Environment"/>
                            </TextBlock>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                            <!-- Authentication Card (collapsible) -->
                            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WindowForeground}">
                                            <Run Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Microsoft Graph Authentication"/>
                                        </TextBlock>
                                        <!-- Auth status indicator -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <Ellipse x:Name="indicator_IntuneAuth" Width="8" Height="8"
                                                     Fill="{DynamicResource StatusError}" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="txt_IntuneAuthLabel" Text="Not Connected"
                                                       FontSize="11" Foreground="{DynamicResource InputPlaceholder}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button x:Name="btn_ToggleAuthCard" Grid.Column="2"
                                                Style="{StaticResource ChevronToggleButton}"
                                                Height="22" Width="22"
                                                Content="&#xE70D;"
                                                ToolTip="Collapse"/>
                                    </Grid>
                                    <StackPanel x:Name="panel_AuthContent" Margin="0,12,0,0">

                                        <!-- Auth method comparison -->
                                        <Grid Margin="0,0,0,14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Interactive (Browser) -->
                                            <Border Grid.Column="0" Background="{DynamicResource InputBackground}"
                                                    CornerRadius="8" Padding="12">
                                                <DockPanel>
                                                    <Border DockPanel.Dock="Bottom" Background="#1A22C55E" CornerRadius="6" Padding="8,6">
                                                        <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                                                   Foreground="#22C55E">
                                                            <Run Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Fastest sign-in. No credentials stored. Supports MFA and Conditional Access natively."/>
                                                        </TextBlock>
                                                    </Border>
                                                    <StackPanel>
                                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6">
                                                            <Run Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Interactive (Browser)"/>
                                                        </TextBlock>
                                                        <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                                                   Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,8">
                                                            Opens your default browser with the Microsoft account picker. Sign in directly — no codes to copy. Tokens refresh silently in the background.
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>

                                            <!-- Interactive / Device Code -->
                                            <Border Grid.Column="2" Background="{DynamicResource InputBackground}"
                                                    CornerRadius="8" Padding="12">
                                                <DockPanel>
                                                    <Border DockPanel.Dock="Bottom" Background="#1A22C55E" CornerRadius="6" Padding="8,6">
                                                        <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                                                   Foreground="#22C55E">
                                                            <Run Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Works in restricted environments. No credentials stored on disk. Tokens expire automatically."/>
                                                        </TextBlock>
                                                    </Border>
                                                    <StackPanel>
                                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6">
                                                            <Run Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Interactive (Device Code)"/>
                                                        </TextBlock>
                                                        <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                                                   Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,8">
                                                            Entra ID issues a short-lived device code you enter at microsoft.com/devicelogin. Use when the browser cannot open automatically.
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>

                                            <!-- App Registration / Client Credentials -->
                                            <Border Grid.Column="4" Background="{DynamicResource InputBackground}"
                                                    CornerRadius="8" Padding="12">
                                                <DockPanel>
                                                    <Border DockPanel.Dock="Bottom" Background="#1AF59E0B" CornerRadius="6" Padding="8,6">
                                                        <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                                                   Foreground="#F59E0B">
                                                            <Run Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Store the client secret securely. Rotate it regularly and apply least privilege."/>
                                                        </TextBlock>
                                                    </Border>
                                                    <StackPanel>
                                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6">
                                                            <Run Text="&#xEBE8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  App Registration (Client Credentials)"/>
                                                        </TextBlock>
                                                        <TextBlock TextWrapping="Wrap" FontSize="13" LineHeight="20"
                                                                   Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,8">
                                                            Authenticates as an Entra ID application using a client secret. Suitable for unattended or automated runs.
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="Authentication Method" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,6"/>
                                        <ComboBox x:Name="cmb_IntuneAuthMode" Height="34" FontSize="13" SelectedIndex="0">
                                            <ComboBoxItem Content="Interactive (Browser)"/>
                                            <ComboBoxItem Content="Interactive (Device Code)"/>
                                            <ComboBoxItem Content="App Registration (Client Credentials)"/>
                                        </ComboBox>

                                    <!-- App Registration Fields (hidden by default) -->
                                    <Border x:Name="panel_AppCredentials" Visibility="Collapsed"
                                            Background="{DynamicResource CardBackground}"
                                            CornerRadius="8" Padding="12" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6">
                                                <Run Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="12"/><Run Text="  Required Graph API Permissions"/>
                                            </TextBlock>
                                            <StackPanel Margin="8,0,0,12">
                                                <TextBlock FontSize="11" Foreground="{DynamicResource InputPlaceholder}" Margin="0,2">
                                                    <Run Text="&#x2022;"/><Run Text="  DeviceManagementApps.ReadWrite.All"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource InputPlaceholder}" Margin="0,2">
                                                    <Run Text="&#x2022;"/><Run Text="  DeviceManagementConfiguration.ReadWrite.All"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource InputPlaceholder}" Margin="0,2">
                                                    <Run Text="&#x2022;"/><Run Text="  DeviceManagementManagedDevices.Read.All"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="{DynamicResource InputPlaceholder}" Margin="0,2">
                                                    <Run Text="&#x2022;"/><Run Text="  Group.Read.All"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Tenant ID" FontSize="12"
                                                           Foreground="{DynamicResource InputPlaceholder}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                                <TextBox x:Name="txt_IntuneTenantId" Grid.Row="0" Grid.Column="1"
                                                         Style="{StaticResource RoundedTextBox}" Height="34" Margin="0,0,0,8"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="App ID" FontSize="12"
                                                           Foreground="{DynamicResource InputPlaceholder}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                                <TextBox x:Name="txt_IntuneAppId" Grid.Row="1" Grid.Column="1"
                                                         Style="{StaticResource RoundedTextBox}" Height="34" Margin="0,0,0,8"/>
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Client Secret" FontSize="12"
                                                           Foreground="{DynamicResource InputPlaceholder}" VerticalAlignment="Center"/>
                                                <PasswordBox x:Name="txt_IntuneClientSecret" Grid.Row="2" Grid.Column="1"
                                                             Style="{StaticResource RoundedPasswordBox}" Height="34"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,12">
                                        <Button x:Name="btn_ConnectIntune"
                                                Style="{StaticResource RoundedButton}" Height="34">
                                            <TextBlock><Run Text="&#xE71B;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Authenticate"/></TextBlock>
                                        </Button>
                                        <Button x:Name="btn_DisconnectIntune"
                                                Style="{StaticResource DangerButton}" Height="34" Margin="8,0,0,0"
                                                Visibility="Collapsed">
                                            <TextBlock><Run Text="&#xE711;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Disconnect"/></TextBlock>
                                        </Button>
                                        <Button x:Name="btn_VerifyIntunePermissions"
                                                Style="{StaticResource SecondaryButton}" Height="34" Margin="8,0,0,0"
                                                Visibility="Collapsed">
                                            <TextBlock><Run Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Verify Permissions"/></TextBlock>
                                        </Button>
                                        <Button x:Name="btn_ResetIntuneAuth"
                                                Style="{StaticResource WarningButton}" Height="34" Margin="8,0,0,0">
                                            <TextBlock><Run Text="&#xE777;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Reset"/></TextBlock>
                                        </Button>
                                    </StackPanel>

                                    <!-- Auth status pill (shown during device code sign-in) -->
                                    <Border x:Name="panel_AuthStatus" Visibility="Collapsed"
                                            Background="#F59E0B" CornerRadius="14" Padding="12,6"
                                            Margin="0,12,0,0" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse x:Name="dot_AuthStatus" Width="8" Height="8"
                                                     Fill="#0F172A" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="txt_AuthStatusMessage" Text="Requesting device code..."
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="#0F172A" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Device code and URL display with copy buttons -->
                                    <StackPanel x:Name="panel_DeviceCode" Visibility="Collapsed" Margin="0,8,0,0">
                                        <!-- Verification URL Row -->
                                        <Border Background="{DynamicResource InputBackground}"
                                                CornerRadius="8" Padding="12" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="URL:" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource InputPlaceholder}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="txt_DeviceCodeUrl" Grid.Column="1"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentColorLight}"
                                                           VerticalAlignment="Center" TextWrapping="Wrap"
                                                           Cursor="Hand"/>
                                                <Button x:Name="btn_CopyDeviceUrl" Grid.Column="2"
                                                        ToolTip="Copy URL to clipboard"
                                                        Height="30" Width="30" Padding="0"
                                                        VerticalAlignment="Center" Margin="8,0,0,0"
                                                        Background="{DynamicResource ButtonSecondary}"
                                                        BorderThickness="0" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                                                    CornerRadius="6" Padding="0">
                                                                <TextBlock x:Name="icon" Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                           Foreground="{DynamicResource ButtonSecondaryForeground}"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background"
                                                                            Value="{DynamicResource ButtonSecondaryHover}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                        <!-- Device Code Row -->
                                        <Border Background="{DynamicResource InputBackground}"
                                                CornerRadius="8" Padding="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Code:" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource InputPlaceholder}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock x:Name="txt_DeviceCodeInfo" Grid.Column="1"
                                                           FontSize="14" FontWeight="Bold"
                                                           Foreground="{DynamicResource WindowForeground}"
                                                           VerticalAlignment="Center" TextWrapping="Wrap"
                                                           Cursor="Hand"/>
                                                <Button x:Name="btn_CopyDeviceCode" Grid.Column="2"
                                                        ToolTip="Copy device code to clipboard"
                                                        Height="30" Width="30" Padding="0"
                                                        VerticalAlignment="Center" Margin="8,0,0,0"
                                                        Background="{DynamicResource ButtonSecondary}"
                                                        BorderThickness="0" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                                                    CornerRadius="6" Padding="0">
                                                                <TextBlock x:Name="icon" Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                           Foreground="{DynamicResource ButtonSecondaryForeground}"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="Background"
                                                                            Value="{DynamicResource ButtonSecondaryHover}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <!-- Graph authentication status -->
                                    <TextBlock x:Name="txt_IntuneGraphStatus" Text="" FontSize="12"
                                               Foreground="{DynamicResource StatusSuccess}" Margin="0,8,0,0"
                                               TextWrapping="Wrap" Visibility="Collapsed"/>

                                    <TextBlock x:Name="txt_IntuneStatus" Text="" FontSize="12"
                                               Foreground="{DynamicResource StatusInfo}" Margin="0,4,0,0"
                                               TextWrapping="Wrap"/>

                                    <!-- Token expiry countdown -->
                                    <TextBlock x:Name="txt_IntuneTokenExpiry" Text="" FontSize="11"
                                               Foreground="{DynamicResource WindowForeground}" Margin="0,4,0,0"
                                               Visibility="Collapsed"/>

                                    <!-- Permission Status Panel -->
                                    <Border x:Name="panel_IntunePermissions" Visibility="Collapsed"
                                            Background="{DynamicResource InputBackground}"
                                            CornerRadius="8" Padding="12" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,8">
                                                <Run Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="12"/><Run Text="  Permission Status"/>
                                            </TextBlock>
                                            <StackPanel x:Name="panel_PermissionItems"/>
                                        </StackPanel>
                                    </Border>

                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Known Model Lookup -->
                            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                        <Run Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Known Model Lookup"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,16" LineHeight="18">
                                        When enabled, the tool queries Microsoft Graph for managed device data to identify 
                                        makes and models actively enrolled in your Intune environment. These known models are 
                                        automatically highlighted in the model selection list, making it easy to target only the 
                                        devices you manage.
                                    </TextBlock>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="chk_IntuneKnownModels"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"/>
                                        <TextBlock x:Name="txt_IntuneKnownModelsState" Grid.Column="1"
                                                   Text="Off" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource InputPlaceholder}"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="btn_IntuneViewModels" Grid.Column="3"
                                                Style="{StaticResource SecondaryButton}" Height="34"
                                                Margin="0,0,8,0" IsEnabled="False">
                                            <TextBlock><Run Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets"/><Run Text="  View Makes / Models"/></TextBlock>
                                        </Button>
                                        <Button x:Name="btn_IntuneKnownModelLookup" Grid.Column="4"
                                                Style="{StaticResource RoundedButton}" Height="34"
                                                IsEnabled="False">
                                            <TextBlock><Run Text="&#xE721;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Query Graph"/></TextBlock>
                                        </Button>
                                    </Grid>
                                    <TextBlock x:Name="txt_IntuneKnownModelStatus" Text="" FontSize="12"
                                               Foreground="{DynamicResource StatusInfo}" Margin="0,8,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- View: Intune Package Options -->
                        <Grid x:Name="view_IntuneOptions" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}">
                                <Run Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="20"/><Run Text="  Package Options"/>
                            </TextBlock>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                            <!-- Toast Notification Preview -->
                            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                        <Run Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Notification Preview"/>
                                    </TextBlock>
                                    <TextBlock Text="This is what users will see during driver or BIOS update notifications."
                                               FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                    <!-- ComboBox to toggle between preview types -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <TextBlock Text="Preview Type" FontSize="11"
                                                   Foreground="{DynamicResource InputPlaceholder}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="cmb_ToastPreviewType" Height="30" Width="200">
                                            <ComboBoxItem Content="Driver Update" IsSelected="True"/>
                                            <ComboBoxItem Content="BIOS Update"/>
                                            <ComboBoxItem Content="BIOS Prestaged"/>
                                            <ComboBoxItem Content="Successfully Updated"/>
                                            <ComboBoxItem Content="Driver Issues"/>
                                            <ComboBoxItem Content="BIOS Issues"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Update toast mockup (Driver / BIOS) -->
                                    <Grid x:Name="panel_ToastUpdateMockup" HorizontalAlignment="Center" Margin="0,0,0,8">
                                        <Border CornerRadius="12" Background="#0F172A" Width="420"
                                                BorderBrush="#334155" BorderThickness="1">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="4" Color="#000000"/>
                                            </Border.Effect>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="100"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <!-- Hero Banner -->
                                                <Border Grid.Row="0" CornerRadius="12,12,0,0" ClipToBounds="True">
                                                    <Border.Background>
                                                        <ImageBrush x:Name="img_ToastBanner" Stretch="UniformToFill"/>
                                                    </Border.Background>
                                                </Border>
                                                <!-- Body Content -->
                                                <StackPanel Grid.Row="1" Margin="20,16,20,12">
                                                    <TextBlock Text="Hi User" FontSize="14" Foreground="#F8FAFC"
                                                               FontWeight="SemiBold" Margin="0,0,0,2"/>
                                                    <TextBlock Text="Driver Automation Tool V10" FontSize="11"
                                                               Foreground="#CBD5E1" Margin="0,0,0,12"/>
                                                    <TextBlock x:Name="txt_ToastHeading" Text="Driver Updates Pending"
                                                               FontSize="17" FontWeight="Bold"
                                                               Foreground="#F8FAFC" Margin="0,0,0,8"/>
                                                    <TextBlock x:Name="txt_ToastBody" TextWrapping="Wrap" FontSize="12"
                                                               Foreground="#CBD5E1" LineHeight="18"
                                                               Text="Your device has pending updates which are required for security / stability reasons. Pressing the Update button can result in temporary network or display interruption."/>
                                                </StackPanel>
                                                <!-- Action Buttons -->
                                                <Grid Grid.Row="2" Margin="20,0,20,16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" CornerRadius="8" Background="#0B84F1"
                                                            Height="36" Cursor="Arrow">
                                                        <TextBlock Text="Update Now" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" FontSize="13"
                                                                   FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                                    </Border>
                                                    <Border Grid.Column="2" CornerRadius="8" Background="#334155"
                                                            Height="36" BorderBrush="#475569" BorderThickness="1"
                                                            Cursor="Arrow">
                                                        <TextBlock Text="Remind Me Later" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" FontSize="13"
                                                                   FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <!-- Status toast mockup (Success / Issues) -->
                                    <Grid x:Name="panel_ToastStatusMockup" HorizontalAlignment="Center" Margin="0,0,0,8" Visibility="Collapsed">
                                        <Border CornerRadius="12" Background="#0F172A" Width="380">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="4" Color="#000000"/>
                                            </Border.Effect>
                                            <Border x:Name="bd_ToastStatusOuter" CornerRadius="12" BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="4"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Border x:Name="bd_ToastStatusStrip" Grid.Row="0" CornerRadius="11,11,0,0"/>
                                                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="24,24,24,12">
                                                        <Border x:Name="bd_ToastStatusIcon" Width="60" Height="60" CornerRadius="30"
                                                                HorizontalAlignment="Center" Margin="0,0,0,14">
                                                            <TextBlock x:Name="txt_ToastStatusIcon"
                                                                       FontFamily="Segoe MDL2 Assets" FontSize="30"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock x:Name="txt_ToastStatusHeading"
                                                                   FontSize="17" FontWeight="Bold" Foreground="#F8FAFC"
                                                                   HorizontalAlignment="Center" TextAlignment="Center"
                                                                   TextWrapping="Wrap" Margin="0,0,0,8"/>
                                                        <TextBlock x:Name="txt_ToastStatusBody"
                                                                   TextWrapping="Wrap" FontSize="12" Foreground="#CBD5E1"
                                                                   HorizontalAlignment="Center" TextAlignment="Center"
                                                                   LineHeight="18" MaxWidth="300"/>
                                                    </StackPanel>
                                                    <Grid Grid.Row="2" Margin="24,0,24,16">
                                                        <Border CornerRadius="8" Background="#334155" Height="34"
                                                                Width="140" HorizontalAlignment="Center"
                                                                BorderBrush="#475569" BorderThickness="1" Cursor="Arrow">
                                                            <TextBlock Text="Close" HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" FontSize="13"
                                                                       FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                                        </Border>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Border>
                                    </Grid>

                                    <!-- Notification Options -->
                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WindowForeground}" Margin="0,24,0,8">
                                        <Run Text="&#xE7E7;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Notification Options"/>
                                    </TextBlock>

                                    <!-- Custom Toast Text -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                <Run Text="&#xE8AC;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Custom Toast Text"/>
                                            </TextBlock>
                                            <TextBlock Text="Override the default heading and body text shown in driver and BIOS update toast notifications."
                                                       FontSize="11" Foreground="{DynamicResource InputPlaceholder}" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="16"/>

                                            <TextBlock Text="Toast Title" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txt_CustomToastTitle" Style="{StaticResource RoundedTextBox}" Height="34" Margin="0,0,0,10"/>

                                            <TextBlock Text="Toast Body" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4"/>
                                            <TextBox x:Name="txt_CustomToastBody" Style="{StaticResource RoundedTextBox}" Height="60"
                                                     TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top"
                                                     Padding="8,6"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Custom Branding -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                <Run Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Custom Branding"/>
                                            </TextBlock>
                                            <TextBlock Text="Replace the default banner image in toast notifications with your own branding. Recommended format: PNG, 460 x 110 pixels."
                                                       FontSize="11" Foreground="{DynamicResource InputPlaceholder}" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="16"/>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="txt_CustomBrandingPath" Grid.Column="0"
                                                         Style="{StaticResource RoundedTextBox}" Height="34"
                                                         IsReadOnly="True"/>
                                                <Button x:Name="btn_BrowseCustomBranding" Grid.Column="1"
                                                        Style="{StaticResource RoundedButton}" Height="30" Margin="6,0,0,0"
                                                        Cursor="Hand">
                                                    <TextBlock FontSize="11"><Run Text="&#xED25;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Browse"/></TextBlock>
                                                </Button>
                                                <Button x:Name="btn_ClearCustomBranding" Grid.Column="2"
                                                        Style="{StaticResource RoundedButton}" Height="30" Margin="6,0,0,0"
                                                        Cursor="Hand" ToolTip="Reset to default banner">
                                                    <TextBlock FontSize="11"><Run Text="&#xE711;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Reset"/></TextBlock>
                                                </Button>
                                            </Grid>

                                            <StackPanel x:Name="panel_BrandingValidation" Orientation="Horizontal" Margin="0,0,0,0" Visibility="Collapsed">
                                                <TextBlock x:Name="txt_BrandingValidationIcon" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBlock x:Name="txt_BrandingValidationText" FontSize="11"
                                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Toast Behaviour -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                <Run Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Toast Behaviour"/>
                                            </TextBlock>
                                            <TextBlock Text="Controls what happens when a user does not interact with the update toast within the 5-minute window."
                                                       FontSize="11" Foreground="{DynamicResource InputPlaceholder}" TextWrapping="Wrap" Margin="0,0,0,10" LineHeight="16"/>

                                            <CheckBox x:Name="chk_DisableToastPrompt" Content="Disable Toast-Based Installation Prompt"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      Foreground="{DynamicResource WindowForeground}"
                                                      FontSize="13" Margin="0,0,0,12"/>

                                            <!-- On timeout action -->
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="On timeout:" FontSize="12" Foreground="{DynamicResource WindowForeground}"
                                                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <ComboBox x:Name="cmb_BIOSTimeoutAction" Grid.Column="1"
                                                          Height="32" FontSize="12"
                                                          Background="{DynamicResource InputBackground}"
                                                          Foreground="{DynamicResource WindowForeground}"
                                                          BorderBrush="{DynamicResource WindowBorder}"
                                                          VerticalContentAlignment="Center">
                                                    <ComboBoxItem Content="Remind Me Later" IsSelected="True"/>
                                                    <ComboBoxItem Content="Auto Install"/>
                                                </ComboBox>
                                            </Grid>

                                            <!-- Max deferrals override -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox x:Name="chk_EnableMaxDeferrals"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBox x:Name="txt_MaxDeferrals" Grid.Column="1"
                                                         Style="{StaticResource RoundedTextBox}" Height="32" FontSize="12"
                                                         Text="3" VerticalContentAlignment="Center" IsEnabled="False"
                                                         ToolTip="Number of times the user can defer before the update is forced"/>
                                                <TextBlock Grid.Column="2"
                                                           Text=" deferrals before forcing install"
                                                           FontSize="12" Foreground="{DynamicResource WindowForeground}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </Border>

                            <!-- Debug Package Build -->
                            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                        <Run Text="&#xEBE8;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Debug Package Build"/>
                                    </TextBlock>
                                    <TextBlock Text="Output pre-IntuneWin staging files (install scripts, WIM, toast scripts) to a local folder for validation and troubleshooting before uploading to Intune."
                                               FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,12" TextWrapping="Wrap" LineHeight="18"/>

                                    <!-- Toggle row -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="chk_DebugPackageBuild"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"/>
                                        <TextBlock x:Name="txt_DebugBuildState" Grid.Column="1"
                                                   Text="Off" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource InputPlaceholder}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Output path -->
                                    <StackPanel x:Name="panel_DebugBuildPath" Visibility="Collapsed" Margin="0,4,0,0">
                                        <TextBlock Text="Debug Output Path" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="txt_DebugBuildPath" Style="{StaticResource RoundedTextBox}" Height="34"
                                                     Tag="Select a folder for debug output" VerticalContentAlignment="Center"/>
                                            <Button x:Name="btn_BrowseDebugBuild" Grid.Column="1"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="34" Margin="8,0,0,0">
                                                <TextBlock><Run Text="&#xED25;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Browse"/></TextBlock>
                                            </Button>
                                        </Grid>
                                        <TextBlock Text="Staging content will be copied to: {path}\{Make}\{Model}"
                                                   FontSize="11" Foreground="{DynamicResource InputPlaceholder}" Margin="0,6,0,0" FontStyle="Italic"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Package Deployment -->
                            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                        <Run Text="&#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Package Deployment"/>
                                    </TextBlock>
                                    <TextBlock Text="Configure automatic deployment behaviour for newly created driver packages."
                                               FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                                    <!-- Deploy All sub-section -->
                                    <TextBlock Text="Deploy all created driver packages to 'All Devices'" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                                    <TextBlock Text="When enabled, each driver package built will be automatically deployed to the built-in All Devices group."
                                               FontSize="13" Foreground="{DynamicResource InputPlaceholder}"
                                               TextWrapping="Wrap" Margin="0,0,0,12" LineHeight="20"/>

                                    <!-- Toggle row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="chk_DeployAllDevices"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,12,0"/>
                                        <TextBlock x:Name="txt_DeployAllState" Grid.Column="1"
                                                   Text="Off" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource InputPlaceholder}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Package Uploads sub-section -->
                                    <Border BorderBrush="{DynamicResource InputBorder}" BorderThickness="0,1,0,0" Margin="0,20,0,0" Padding="0,16,0,0">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                <Run Text="&#xE898;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Package Uploads"/>
                                            </TextBlock>
                                            <TextBlock Text="Tune upload performance for Intune Win32 app packages. Larger chunks and more parallel uploads can significantly reduce upload times for large driver packages."
                                                       FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,16" TextWrapping="Wrap" LineHeight="18"/>

                                            <!-- Chunk Size -->
                                            <TextBlock Text="Chunk Size" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4"/>
                                            <TextBlock Text="Size of each block uploaded to Azure Blob Storage. Larger chunks reduce HTTP overhead and round-trips but use more memory per upload. Default: 50 MB."
                                                       FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,8" TextWrapping="Wrap" LineHeight="18"/>
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox x:Name="cmb_IntuneChunkSize" Grid.Column="0" Height="34">
                                                    <ComboBoxItem Content="4 MB" Tag="4"/>
                                                    <ComboBoxItem Content="6 MB" Tag="6"/>
                                                    <ComboBoxItem Content="10 MB" Tag="10"/>
                                                    <ComboBoxItem Content="25 MB" Tag="25"/>
                                                    <ComboBoxItem Content="50 MB (Default)" Tag="50" IsSelected="True"/>
                                                    <ComboBoxItem Content="100 MB" Tag="100"/>
                                                </ComboBox>
                                                <TextBlock Grid.Column="1" x:Name="txt_ChunkSizeHint" FontSize="11"
                                                           Foreground="{DynamicResource InputPlaceholder}"
                                                           VerticalAlignment="Center" Margin="12,0,0,0"
                                                           Text="Recommended: 25 MB+ for packages over 500 MB"/>
                                            </Grid>

                                            <!-- Parallel Uploads -->
                                            <TextBlock Text="Parallel Uploads" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4"/>
                                            <TextBlock Text="Number of chunks uploaded simultaneously. Higher values improve throughput but increase network and memory usage. Values above 4 may trigger Azure throttling on slower connections."
                                                       FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,8" TextWrapping="Wrap" LineHeight="18"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox x:Name="cmb_IntuneParallelUploads" Grid.Column="0" Height="34">
                                                    <ComboBoxItem Content="1 (Sequential)" Tag="1"/>
                                                    <ComboBoxItem Content="2 threads (Default)" Tag="2" IsSelected="True"/>
                                                    <ComboBoxItem Content="4 threads" Tag="4"/>
                                                    <ComboBoxItem Content="8 threads" Tag="8"/>
                                                </ComboBox>
                                                <TextBlock Grid.Column="1" x:Name="txt_ParallelHint" FontSize="11"
                                                           Foreground="{DynamicResource InputPlaceholder}"
                                                           VerticalAlignment="Center" Margin="12,0,0,0"
                                                           Text="Recommended: 2–4 threads for most connections"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            </StackPanel>
                            </ScrollViewer>
                        </Grid>
                        <Grid x:Name="view_IntunePackageMgmt" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="2*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}">
                                <Run Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets" FontSize="20"/><Run Text="  Package Management"/>
                            </TextBlock>

                            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Column="0" Grid.Row="0" Text="Package Type" FontSize="11"
                                               Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,8,4"/>

                                    <ComboBox x:Name="cmb_IntunePkgType" Grid.Column="0" Grid.Row="1" Margin="0,0,8,0" Height="34">
                                        <ComboBoxItem Content="Drivers" IsSelected="True"/>
                                        <ComboBoxItem Content="BIOS Update"/>
                                    </ComboBox>
                                    <Button x:Name="btn_RefreshIntuneApps" Grid.Column="1" Grid.Row="1"
                                            Style="{StaticResource SecondaryButton}" Height="34" Margin="0,0,0,0"
                                            IsEnabled="False">
                                        <TextBlock><Run Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Refresh"/></TextBlock>
                                    </Button>
                                </Grid>
                            </Border>

                            <TextBlock x:Name="txt_IntunePkgStatus" Grid.Row="2" FontSize="12"
                                       Foreground="{DynamicResource StatusWarning}" Margin="0,0,0,8"
                                       Text="Not connected to Intune. Please connect first."
                                       Visibility="Visible"/>

                            <!-- Search bar + Select All/None + Delete -->
                            <Grid Grid.Row="3" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="txt_IntuneAppSearch" Grid.Column="0"
                                         Style="{StaticResource RoundedTextBox}"
                                         Tag="Enter text to search"
                                         Height="34" Margin="0,0,8,0"/>
                                <Button x:Name="btn_IntunePkgSelectAll" Grid.Column="1"
                                        Style="{StaticResource SecondaryButton}" Height="34" Margin="0,0,4,0">
                                    <TextBlock><Run Text="&#xE73A;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Select All"/></TextBlock>
                                </Button>
                                <Button x:Name="btn_IntunePkgSelectNone" Grid.Column="2"
                                        Style="{StaticResource SecondaryButton}" Height="34" Margin="0,0,4,0">
                                    <TextBlock><Run Text="&#xE739;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Select None"/></TextBlock>
                                </Button>
                                <Button x:Name="btn_DeleteIntuneApp" Grid.Column="3"
                                        Style="{StaticResource DangerButton}" Height="34"
                                        IsEnabled="False">
                                    <TextBlock><Run Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Delete Selected"/></TextBlock>
                                </Button>
                            </Grid>

                            <Border Grid.Row="4" Style="{StaticResource CardPanel}">
                                <DataGrid x:Name="grid_IntuneApps"
                                          Style="{StaticResource ModernDataGrid}"
                                          BorderThickness="0"
                                          IsEnabled="False">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu x:Name="ctx_IntuneMenu"
                                                     HasDropShadow="True"
                                                     Padding="0">
                                            <ContextMenu.Template>
                                                <ControlTemplate TargetType="ContextMenu">
                                                    <Border Background="{DynamicResource CardBackground}"
                                                            BorderBrush="{DynamicResource CardBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Padding="4,6"
                                                            SnapsToDevicePixels="True">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="16" Opacity="0.35" ShadowDepth="4" Color="Black"/>
                                                        </Border.Effect>
                                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </ContextMenu.Template>
                                            <ContextMenu.Resources>
                                                <Style TargetType="MenuItem">
                                                    <Setter Property="Foreground" Value="{DynamicResource SidebarForeground}"/>
                                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="Padding" Value="12,8"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="MenuItem">
                                                                <Border x:Name="MenuItemBorder"
                                                                        Background="Transparent"
                                                                        Padding="{TemplateBinding Padding}"
                                                                        CornerRadius="4"
                                                                        Margin="2,1">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <ContentPresenter Grid.Column="0"
                                                                                          Content="{TemplateBinding Icon}"
                                                                                          VerticalAlignment="Center"
                                                                                          Margin="0,0,10,0"/>
                                                                        <ContentPresenter Grid.Column="1"
                                                                                          ContentSource="Header"
                                                                                          VerticalAlignment="Center"/>
                                                                    </Grid>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsHighlighted" Value="True">
                                                                        <Setter TargetName="MenuItemBorder" Property="Background"
                                                                                Value="{DynamicResource SidebarHover}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter Property="Opacity" Value="0.4"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                                <Style TargetType="Separator">
                                                    <Setter Property="Background" Value="{DynamicResource CardBorder}"/>
                                                    <Setter Property="Margin" Value="8,4"/>
                                                    <Setter Property="Height" Value="1"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Separator">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        Height="{TemplateBinding Height}"
                                                                        Margin="{TemplateBinding Margin}"
                                                                        SnapsToDevicePixels="True"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ContextMenu.Resources>

                                            <!-- Header -->
                                            <MenuItem IsHitTestVisible="False" IsEnabled="False" Padding="10,8">
                                                <MenuItem.Template>
                                                    <ControlTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="10,4,10,2">
                                                            <Image x:Name="ctx_IntuneHeaderLogo"
                                                                   Width="20" Height="20"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,8,0"
                                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                                            <TextBlock Text="Assignment Options"
                                                                       FontFamily="Segoe UI"
                                                                       FontSize="13"
                                                                       FontWeight="Bold"
                                                                       Foreground="{DynamicResource SidebarForeground}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ControlTemplate>
                                                </MenuItem.Template>
                                            </MenuItem>

                                            <Separator/>

                                            <MenuItem x:Name="ctx_AssignAvailable" Header="Assign Package — Available">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               Foreground="{DynamicResource AccentColor}"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem x:Name="ctx_AssignRequired" Header="Assign Package — Required">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               Foreground="{DynamicResource StatusWarning}"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="&#x2611;" Width="40" CanUserSort="False">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding Selected, UpdateSourceTrigger=PropertyChanged}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Display Name" Width="*"
                                                            Binding="{Binding DisplayName}" IsReadOnly="True"
                                                            SortMemberPath="DisplayName"/>
                                        <DataGridTextColumn Header="Publisher" Width="140"
                                                            Binding="{Binding Publisher}" IsReadOnly="True"
                                                            SortMemberPath="Publisher"/>
                                        <DataGridTextColumn Header="Version" Width="100"
                                                            Binding="{Binding Version}" IsReadOnly="True"
                                                            SortMemberPath="Version"/>
                                        <DataGridTextColumn Header="Created" Width="120"
                                                            Binding="{Binding CreatedDate}" IsReadOnly="True"
                                                            SortMemberPath="CreatedDate"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <!-- Package Detail Panel -->
                            <Border x:Name="panel_IntuneAppDetail" Grid.Row="5" Style="{StaticResource CardPanel}" Margin="0,12,0,0" Visibility="Collapsed">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WindowForeground}">
                                            <Run Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Package Details"/>
                                        </TextBlock>
                                        <Button x:Name="btn_IntuneReportIssue" Grid.Column="1"
                                                Style="{StaticResource WarningButton}" Height="30">
                                            <TextBlock><Run Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Report Issue"/></TextBlock>
                                        </Button>
                                        <Button x:Name="btn_IntuneDeletePackage" Grid.Column="2"
                                                Style="{StaticResource DangerButton}" Height="30"
                                                Margin="8,0,0,0">
                                            <TextBlock><Run Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Delete"/></TextBlock>
                                        </Button>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- App ID -->
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="APP ID" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}"
                                                       Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="txt_Detail_AppId" Grid.Column="0"
                                                           FontSize="11" FontFamily="Consolas"
                                                           Foreground="{DynamicResource AccentColorLight}"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Button x:Name="btn_Detail_CopyId" Grid.Column="1"
                                                        Height="22" Width="22" Padding="0"
                                                        Margin="6,0,0,0" BorderThickness="0"
                                                        Cursor="Hand" ToolTip="Copy App ID"
                                                        Background="{DynamicResource ButtonSecondary}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5">
                                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                           Foreground="{DynamicResource ButtonSecondaryForeground}"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonSecondaryHover}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>

                                            <TextBlock Text="DISPLAY NAME" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}"
                                                       Margin="0,10,0,4"/>
                                            <TextBlock x:Name="txt_Detail_Name"
                                                       FontSize="11" Foreground="{DynamicResource WindowForeground}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Install Command -->
                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Text="PUBLISHER" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="txt_Detail_Publisher"
                                                       FontSize="11" Foreground="{DynamicResource WindowForeground}"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <TextBlock Text="INSTALL COMMAND" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}"
                                                       Margin="0,10,0,4"/>
                                            <TextBlock x:Name="txt_Detail_InstallCmd"
                                                       FontSize="11" FontFamily="Consolas"
                                                       Foreground="{DynamicResource WindowForeground}"
                                                       TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                        </StackPanel>

                                        <!-- Description -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="DESCRIPTION" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="txt_Detail_Description"
                                                       FontSize="11" Foreground="{DynamicResource WindowForeground}"
                                                       TextWrapping="Wrap" MaxHeight="56"
                                                       TextTrimming="WordEllipsis"/>

                                            <TextBlock Text="VERSION" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}"
                                                       Margin="0,10,0,4"/>
                                            <TextBlock x:Name="txt_Detail_Version"
                                                       FontSize="11" Foreground="{DynamicResource WindowForeground}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- View: BIOS Security -->
                        <Grid x:Name="view_BIOSSecurity" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}">
                                <Run Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="20"/><Run Text="  BIOS Security"/>
                            </TextBlock>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <!-- Overview Card -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                <Run Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  About BIOS Password Encryption"/>
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,12" LineHeight="18">
                                                BIOS passwords are encrypted using Windows Data Protection API (DPAPI) with machine-scope encryption. 
                                                The encrypted password is stored in the registry at HKLM:\SOFTWARE\MSEndpointMgr\DriverAutomationTool\BIOS 
                                                and can only be decrypted by the SYSTEM account on the same device. This ensures the password is never 
                                                stored or transmitted in clear text.
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                                       Foreground="{DynamicResource InputPlaceholder}" LineHeight="18">
                                                Use the Intune Proactive Remediation scripts below to deploy the encrypted BIOS password to your managed devices. 
                                                The Detection script verifies the password exists and is decryptable. The Remediation script encrypts 
                                                and stores the password using DPAPI machine-scope protection.
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Password Input Card -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                <Run Text="&#xE785;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  BIOS Password"/>
                                            </TextBlock>
                                            <TextBlock Text="Enter the BIOS password to embed in the remediation scripts."
                                                       FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*" MaxWidth="400"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="BIOS Password" FontSize="12"
                                                           Foreground="{DynamicResource WindowForeground}"
                                                           VerticalAlignment="Center"/>
                                                <Grid Grid.Column="1">
                                                    <PasswordBox x:Name="txt_BIOSPassword"
                                                                 Style="{StaticResource RoundedPasswordBox}"
                                                                 Height="32" FontSize="12"
                                                                 VerticalContentAlignment="Center"
                                                                 MaxLength="64"/>
                                                    <TextBox x:Name="txt_BIOSPasswordPlain"
                                                             Style="{StaticResource RoundedTextBox}"
                                                             Height="32" FontSize="12"
                                                             VerticalContentAlignment="Center"
                                                             MaxLength="64" Visibility="Collapsed"
                                                             IsReadOnly="True"/>
                                                </Grid>
                                                <Button x:Name="btn_PeekBIOSPassword" Grid.Column="2"
                                                        Width="32" Height="32" Margin="6,0,0,0"
                                                        Cursor="Hand" ToolTip="Hold to reveal password">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="PeekBorder"
                                                                    CornerRadius="6"
                                                                    Background="{DynamicResource InputBackground}"
                                                                    BorderBrush="{DynamicResource InputBorder}"
                                                                    BorderThickness="1">
                                                                <TextBlock x:Name="PeekIcon"
                                                                           Text="&#xE7B3;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                           Foreground="{DynamicResource InputPlaceholder}"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="PeekBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                                                    <Setter TargetName="PeekBorder" Property="Background" Value="{DynamicResource ButtonPrimary}"/>
                                                                    <Setter TargetName="PeekIcon" Property="Foreground" Value="{DynamicResource ButtonPrimaryForeground}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>

                                            <TextBlock x:Name="txt_BIOSPasswordStatus" Text="" FontSize="11"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4"/>

                                            <!-- HP Password BIN File (Optional) -->
                                            <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource CardBorder}" Margin="0,12,0,0" Padding="0,12,0,0">
                                                <StackPanel>
                                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                        <Run Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  HP Password BIN File (Optional)"/>
                                                    </TextBlock>
                                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                                               Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,10" LineHeight="16">
                                                        Specify a pre-existing HP firmware password BIN file to embed in HP BIOS packages instead of generating one at runtime.
                                                    </TextBlock>

                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="140"/>
                                                            <ColumnDefinition Width="*" MaxWidth="400"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="BIN File Path" FontSize="12"
                                                                   Foreground="{DynamicResource WindowForeground}"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBox x:Name="txt_HPPasswordBinPath"
                                                                 Grid.Column="1"
                                                                 Style="{StaticResource RoundedTextBox}"
                                                                 Height="32" FontSize="12"
                                                                 VerticalContentAlignment="Center"
                                                                 IsReadOnly="True"/>
                                                        <Button x:Name="btn_BrowseHPPasswordBin" Grid.Column="2"
                                                                Width="32" Height="32" Margin="6,0,0,0"
                                                                Cursor="Hand" ToolTip="Browse for HP password BIN file">
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="BrowseBorder"
                                                                            CornerRadius="6"
                                                                            Background="{DynamicResource InputBackground}"
                                                                            BorderBrush="{DynamicResource InputBorder}"
                                                                            BorderThickness="1">
                                                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                                   Foreground="{DynamicResource InputPlaceholder}"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="BrowseBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </Grid>

                                                    <StackPanel Orientation="Horizontal">
                                                        <Button x:Name="btn_ClearHPPasswordBin"
                                                                Height="30" Width="100" HorizontalAlignment="Left"
                                                                Style="{StaticResource RoundedButton}" Margin="0,0,8,0"
                                                                IsEnabled="False">
                                                            <TextBlock FontSize="11">
                                                                <Run Text="&#xE711;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Clear"/>
                                                            </TextBlock>
                                                        </Button>
                                                        <TextBlock x:Name="txt_HPPasswordBinStatus" Text="" FontSize="11"
                                                                   Foreground="{DynamicResource InputPlaceholder}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Export Remediation Scripts Card -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                <Run Text="&#xE78C;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Export Remediation Scripts"/>
                                            </TextBlock>
                                            <TextBlock Text="Export the Intune Proactive Remediation detection and remediation scripts with the BIOS password embedded."
                                                       FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                            <Button x:Name="btn_ExportBIOSRemediation"
                                                    Height="36" Width="220" HorizontalAlignment="Left"
                                                    Style="{StaticResource RoundedButton}">
                                                <TextBlock FontSize="12">
                                                    <Run Text="&#xE896;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Export Scripts"/>
                                                </TextBlock>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- View: Common Settings -->
                        <Grid x:Name="view_CommonSettings" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}">
                                <Run Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="20"/><Run Text="  Common Settings"/>
                            </TextBlock>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,12">
                                                <Run Text="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Storage Paths"/>
                                            </TextBlock>

                                            <TextBlock FontSize="11" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4">
                                                <Run Text="Temporary Storage Path" FontWeight="SemiBold"/><Run Text=" — This is a local path used for downloading and creating packages"/>
                                            </TextBlock>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="txt_TempStorage" Style="{StaticResource RoundedTextBox}" Height="34"/>
                                                <Button x:Name="btn_BrowseTemp" Grid.Column="1"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Height="34" Margin="8,0,0,0">
                                                    <TextBlock><Run Text="&#xED25;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Browse"/></TextBlock>
                                                </Button>
                                            </Grid>
                                            <Grid x:Name="grid_TempFreeSpace" Margin="0,6,0,0" Visibility="Collapsed">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <ProgressBar x:Name="progress_TempFreeSpace" Grid.Row="0" Height="6" Minimum="0" Maximum="100"
                                                             Background="{DynamicResource InputBackground}" Foreground="#3B82F6"
                                                             BorderThickness="0"/>
                                                <TextBlock x:Name="txt_TempFreeSpace" Grid.Row="1" FontSize="10" Margin="0,4,0,0"
                                                           Foreground="{DynamicResource InputPlaceholder}" HorizontalAlignment="Right"/>
                                            </Grid>

                                            <TextBlock Text="Package Storage Path" FontSize="11"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,12,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="txt_PackageStorage" Style="{StaticResource RoundedTextBox}" Height="34"/>
                                                <Button x:Name="btn_BrowsePackage" Grid.Column="1"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Height="34" Margin="8,0,0,0">
                                                    <TextBlock><Run Text="&#xED25;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Browse"/></TextBlock>
                                                </Button>
                                            </Grid>
                                            <Grid x:Name="grid_PackageFreeSpace" Margin="0,6,0,0" Visibility="Collapsed">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <ProgressBar x:Name="progress_PackageFreeSpace" Grid.Row="0" Height="6" Minimum="0" Maximum="100"
                                                             Background="{DynamicResource InputBackground}" Foreground="#3B82F6"
                                                             BorderThickness="0"/>
                                                <TextBlock x:Name="txt_PackageFreeSpace" Grid.Row="1" FontSize="10" Margin="0,4,0,0"
                                                           Foreground="{DynamicResource InputPlaceholder}" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Purge Downloads -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6">
                                                <Run Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Purge Downloads"/>
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,10">
                                                Removes all downloaded and extracted driver packages from the temporary storage path. This frees disk space without affecting packaged output.
                                            </TextBlock>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="btn_PurgeDownloads" Grid.Column="0"
                                                        Style="{StaticResource DangerButton}" Height="34">
                                                    <TextBlock><Run Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Purge Downloads"/></TextBlock>
                                                </Button>
                                                <TextBlock x:Name="txt_PurgeStatus" Grid.Column="1" Text="" FontSize="12"
                                                           Foreground="{DynamicResource StatusInfo}" VerticalAlignment="Center" Margin="12,0,0,0"
                                                           TextWrapping="Wrap"/>
                                            </Grid>

                                            <!-- Clean Temp on Exit Toggle -->
                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox x:Name="chk_CleanTempOnExit" Grid.Column="0"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          IsChecked="True"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <TextBlock Text="Clean temporary storage on exit" FontSize="13"
                                                               Foreground="{DynamicResource WindowForeground}"/>
                                                    <TextBlock Text="Automatically removes downloaded and extracted files when the application closes."
                                                               FontSize="11" Foreground="{DynamicResource InputPlaceholder}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Proxy Configuration -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,12">
                                                <Run Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Proxy Configuration"/>
                                            </TextBlock>
                                            <TextBlock Text="Configure proxy settings for network connectivity. System proxy is used by default."
                                                       FontSize="12" Foreground="{DynamicResource InputPlaceholder}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                            <TextBlock Text="Proxy Mode" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="cmb_ProxyMode" Width="200" HorizontalAlignment="Left"
                                                      Height="34" Margin="0,0,0,12">
                                                <ComboBoxItem Content="Use System Proxy" IsSelected="True"/>
                                                <ComboBoxItem Content="Manual"/>
                                                <ComboBoxItem Content="No Proxy"/>
                                            </ComboBox>

                                            <StackPanel x:Name="panel_ProxyManual" Visibility="Collapsed">
                                                <TextBlock Text="Proxy Server" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,6"/>
                                                <TextBox x:Name="txt_ProxyServer" Style="{StaticResource RoundedTextBox}"
                                                         Height="36" Margin="0,0,0,8"/>
                                                <TextBlock Text="Example: http://proxy.company.com:8080" FontSize="11"
                                                           Foreground="{DynamicResource InputPlaceholder}" FontStyle="Italic" Margin="0,0,0,12"/>

                                                <TextBlock Text="Bypass List (semicolon-separated)" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,6"/>
                                                <TextBox x:Name="txt_ProxyBypass" Style="{StaticResource RoundedTextBox}"
                                                         Height="36" Margin="0,0,0,8"/>
                                                <TextBlock Text="Example: *.local;10.*;192.168.*" FontSize="11"
                                                           Foreground="{DynamicResource InputPlaceholder}" FontStyle="Italic" Margin="0,0,0,12"/>

                                                <TextBlock Text="Authentication (leave blank to use Windows credentials)" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,6"/>
                                                <Grid Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Username" FontSize="11"
                                                                   Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4"/>
                                                        <TextBox x:Name="txt_ProxyUsername" Style="{StaticResource RoundedTextBox}"
                                                                 Height="36"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Password" FontSize="11"
                                                                   Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4"/>
                                                        <PasswordBox x:Name="pwd_ProxyPassword" Height="36"
                                                                     Background="{DynamicResource InputBackground}"
                                                                     Foreground="{DynamicResource InputForeground}"
                                                                     BorderBrush="{DynamicResource InputBorder}"
                                                                     BorderThickness="1" Padding="8,0"
                                                                     VerticalContentAlignment="Center" FontSize="13"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="btn_TestProxy" Grid.Column="0"
                                                        Style="{StaticResource SecondaryButton}" Height="34">
                                                    <TextBlock><Run Text="&#xE968;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Test Connection"/></TextBlock>
                                                </Button>
                                                <TextBlock x:Name="txt_ProxyStatus" Grid.Column="1" Text="" FontSize="12"
                                                           Foreground="{DynamicResource StatusInfo}" VerticalAlignment="Center" Margin="12,0,0,0"
                                                           TextWrapping="Wrap"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- External Utilities & Modules -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,12">
                                                <Run Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  External Utilities &amp; Modules"/>
                                            </TextBlock>

                                            <!-- HP CMSL Section -->
                                            <TextBlock Text="HP Client Management Script Library (HPCMSL)" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,10">
                                                The Driver Automation Tool uses the HPCMSL PowerShell module to create driver and BIOS packages for HP devices. Without this module installed, HP will be unavailable as a manufacturer option.
                                            </TextBlock>
                                            <Border Background="{DynamicResource InputBackground}" CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="txt_HpcmslStatusIcon" Grid.Column="0"
                                                               FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               VerticalAlignment="Center" Margin="0,0,10,0"
                                                               Foreground="{DynamicResource InputPlaceholder}"
                                                               Text="&#xE946;"/>
                                                    <TextBlock x:Name="txt_HpcmslStatus" Grid.Column="1"
                                                               FontSize="12" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource InputPlaceholder}"
                                                               Text="Checking HPCMSL status..."/>
                                                    <Button x:Name="btn_InstallHpcmsl" Grid.Column="2"
                                                            Style="{StaticResource SecondaryButton}" Height="30"
                                                            Margin="10,0,0,0" Visibility="Collapsed">
                                                        <TextBlock FontSize="12">
                                                            <Run Text="&#xE896;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Install Module"/>
                                                        </TextBlock>
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <!-- HP Concurrent SoftPaq Downloads -->
                                            <TextBlock Text="Concurrent SoftPaq Downloads" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4"/>
                                            <TextBlock Text="Number of HP SoftPaq files downloaded simultaneously during driver pack creation. Higher values speed up downloads but increase network and memory usage."
                                                       FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,8" TextWrapping="Wrap" LineHeight="18"/>
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="200"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ComboBox x:Name="cmb_HPConcurrentDownloads" Grid.Column="0" Height="34">
                                                    <ComboBoxItem Content="1 (Sequential)" Tag="1"/>
                                                    <ComboBoxItem Content="2 (Default)" Tag="2" IsSelected="True"/>
                                                    <ComboBoxItem Content="3" Tag="3"/>
                                                    <ComboBoxItem Content="4" Tag="4"/>
                                                </ComboBox>
                                                <TextBlock Grid.Column="1" FontSize="11"
                                                           Foreground="{DynamicResource InputPlaceholder}"
                                                           VerticalAlignment="Center" Margin="12,0,0,0"
                                                           Text="Recommended: 2 for most connections"/>
                                            </Grid>

                                            <!-- Divider -->
                                            <Border Height="1" Background="{DynamicResource SidebarActive}" Margin="0,0,0,14"/>

                                            <!-- CURL Section -->
                                            <TextBlock Text="CURL Download Utility" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4">
                                                CURL is used for downloading driver packages with resume support and automatic retry. By default, the built-in Windows system curl is used. You can also use a third-party bundled copy from the Tools folder.
                                            </TextBlock>
                                            <StackPanel x:Name="panel_CurlThirdParty" Visibility="Collapsed">
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4">
                                                <Run Text="Download curl from "/><Hyperlink x:Name="link_CurlDownload"
                                                    NavigateUri="https://curl.se/download.html"
                                                    Foreground="{DynamicResource AccentColor}">curl.se/download.html</Hyperlink><Run Text=" and place curl.exe in the "/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" FontFamily="Cascadia Code,Consolas,monospace"
                                                       Foreground="{DynamicResource AccentColor}" Margin="0,0,0,10">
                                                <Run Text="Tools\"/><Run Text=" folder within the application directory."/>
                                            </TextBlock>

                                            <Border Background="{DynamicResource InputBackground}" CornerRadius="6" Padding="12,10" Margin="0,0,0,14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="txt_CurlStatusIcon" Grid.Column="0"
                                                               FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               VerticalAlignment="Center" Margin="0,0,10,0"
                                                               Foreground="{DynamicResource InputPlaceholder}"
                                                               Text="&#xE946;"/>
                                                    <TextBlock x:Name="txt_CurlStatus" Grid.Column="1"
                                                               FontSize="12" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource InputPlaceholder}"
                                                               Text="Checking curl status..."/>
                                                </Grid>
                                            </Border>
                                            </StackPanel>

                                            <!-- CURL Source -->
                                            <TextBlock Text="CURL Source" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,6"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,8">
                                                Select the curl binary used for downloads. Built-in uses the Windows system curl (available on Windows 10 1803+). Third Party uses the bundled curl.exe from the Tools folder, with automatic fallback to the built-in version if unavailable or blocked.
                                            </TextBlock>
                                            <ComboBox x:Name="cmb_CurlSource" Height="34" Width="Auto" MinWidth="180"
                                                      HorizontalAlignment="Left" Margin="0,0,0,14">
                                                <ComboBoxItem Content="Built-in (System)" IsSelected="True"/>
                                                <ComboBoxItem Content="Third Party (Bundled)"/>
                                            </ComboBox>

                                            <!-- Running Mode -->
                                            <TextBlock Text="CURL Running Mode" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,6"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="20"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,8">
                                                Controls whether the curl window is visible during downloads. Silent mode hides the window; Show Window mode lets you observe download progress directly.
                                            </TextBlock>
                                            <ComboBox x:Name="cmb_CurlRunMode" Height="34" Width="Auto" MinWidth="140"
                                                      HorizontalAlignment="Left">
                                                <ComboBoxItem Content="Silent" IsSelected="True"/>
                                                <ComboBoxItem Content="Show Window"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>

                                    <!-- WIM Packaging Options -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                <Run Text="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  WIM Packaging"/>
                                            </TextBlock>

                                            <!-- WIM Engine Selection -->
                                            <TextBlock Text="WIM Creation Engine" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,8,0,6"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4">
                                                Select the engine used to create WIM packages. DISM is built into Windows but is single-threaded and slower. wimlib is an open-source alternative that supports multi-threaded compression for significantly faster packaging. 7-Zip also supports WIM creation if installed.
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" LineHeight="18"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4">
                                                <Run Text="Download wimlib from "/><Hyperlink x:Name="link_WimlibDownload"
                                                    NavigateUri="https://wimlib.net/"
                                                    Foreground="{DynamicResource AccentColor}">wimlib.net</Hyperlink><Run Text=" and place wimlib-imagex.exe and its dependencies in the "/><Run Text="Tools\Wimlib\" FontFamily="Cascadia Code,Consolas,monospace"/><Run Text=" folder. Download 7-Zip from "/><Hyperlink x:Name="link_7ZipDownload"
                                                    NavigateUri="https://www.7-zip.org/"
                                                    Foreground="{DynamicResource AccentColor}">7-zip.org</Hyperlink><Run Text=" and install normally."/>
                                            </TextBlock>

                                            <Border Background="{DynamicResource InputBackground}" CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="txt_WimlibStatusIcon" Grid.Column="0"
                                                               FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               VerticalAlignment="Center" Margin="0,0,10,0"
                                                               Foreground="{DynamicResource InputPlaceholder}"
                                                               Text="&#xE946;"/>
                                                    <TextBlock x:Name="txt_WimlibStatus" Grid.Column="1"
                                                               FontSize="12" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource InputPlaceholder}"
                                                               Text="Checking wimlib status..."/>
                                                </Grid>
                                            </Border>

                                            <Border Background="{DynamicResource InputBackground}" CornerRadius="6" Padding="12,10" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="txt_7ZipStatusIcon" Grid.Column="0"
                                                               FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                               VerticalAlignment="Center" Margin="0,0,10,0"
                                                               Foreground="{DynamicResource InputPlaceholder}"
                                                               Text="&#xE946;"/>
                                                    <TextBlock x:Name="txt_7ZipStatus" Grid.Column="1"
                                                               FontSize="12" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource InputPlaceholder}"
                                                               Text="Checking 7-Zip status..."/>
                                                </Grid>
                                            </Border>

                                            <ComboBox x:Name="cmb_WimEngine" Height="34" Width="Auto" MinWidth="180"
                                                      HorizontalAlignment="Left" Margin="0,0,0,4">
                                                <ComboBoxItem Content="DISM (Built-in)" IsSelected="True"/>
                                                <ComboBoxItem x:Name="cmbi_Wimlib" Content="wimlib (Multi-threaded)"/>
                                                <ComboBoxItem x:Name="cmbi_7Zip" Content="7-Zip"/>
                                            </ComboBox>

                                            <!-- WIM Compression Level -->
                                            <TextBlock Text="WIM Compression Level" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,16,0,6"/>
                                            <TextBlock x:Name="txt_CompressionDescription" TextWrapping="Wrap" FontSize="12" LineHeight="18"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,8">
                                                Controls compression when creating WIM packages. Fast (XPRESS) is recommended for most scenarios. Maximum (LZX) produces smaller files but is significantly slower.
                                            </TextBlock>
                                            <ComboBox x:Name="cmb_DismCompression" Height="34" Width="Auto" MinWidth="140"
                                                      HorizontalAlignment="Left">
                                                <ComboBoxItem Content="Fast (Recommended)" IsSelected="True"/>
                                                <ComboBoxItem Content="Maximum"/>
                                                <ComboBoxItem Content="None"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Border>

                                    <!-- Package Retention -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                <Run Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Package Retention"/>
                                            </TextBlock>
                                            <TextBlock Text="Automatically remove superseded driver and BIOS packages when a newer version is created for the same make, model and OS. Applies to both Configuration Manager and Intune."
                                                       FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,16"/>

                                            <!-- Auto-cleanup toggle -->
                                            <TextBlock Text="Automatically clean up superseded packages" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                                            <TextBlock Text="When enabled, older packages for the same make/model/OS are deleted automatically after a successful build."
                                                       FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,12"/>
                                            <Grid Margin="0,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox x:Name="chk_PackageRetentionEnabled"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,12,0"/>
                                                <TextBlock x:Name="txt_PackageRetentionState" Grid.Column="1"
                                                           Text="Off" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource InputPlaceholder}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- Versions to keep -->
                                            <Border x:Name="panel_RetentionCount" BorderBrush="{DynamicResource InputBorder}"
                                                    BorderThickness="0,1,0,0" Margin="0,20,0,0" Padding="0,16,0,0"
                                                    Visibility="Collapsed">
                                                <StackPanel>
                                                    <TextBlock Text="Retention" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                                                    <TextBlock Text="Choose how many previous versions to keep per make/model/OS. Selecting 0 removes all superseded versions, keeping only the latest."
                                                               FontSize="12" TextWrapping="Wrap"
                                                               Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,12"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ComboBox x:Name="cmb_RetentionCount"
                                                                  Width="80" Height="34"
                                                                  HorizontalAlignment="Left">
                                                            <ComboBoxItem Content="0" IsSelected="True"/>
                                                            <ComboBoxItem Content="1"/>
                                                            <ComboBoxItem Content="2"/>
                                                            <ComboBoxItem Content="3"/>
                                                            <ComboBoxItem Content="4"/>
                                                            <ComboBoxItem Content="5"/>
                                                        </ComboBox>
                                                        <TextBlock Grid.Column="1" Text="previous version(s) retained"
                                                                   FontSize="12" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource InputPlaceholder}"
                                                                   Margin="10,0,0,0"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Telemetry Collection -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,12">
                                                <Run Text="&#xEB51;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Telemetry Collection"/>
                                            </TextBlock>

                                            <TextBlock Text="When enabled, anonymous telemetry data is collected to help improve this tool and enable usage reporting."
                                                       FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,8"/>

                                            <TextBlock FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4">
                                                <Run Text="  &#x2022;  Number of driver and BIOS packages"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4">
                                                <Run Text="  &#x2022;  Models associated with each package"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4">
                                                <Run Text="  &#x2022;  External IP address"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,8">
                                                <Run Text="  &#x2022;  Package issue state for reporting purposes"/>
                                            </TextBlock>

                                            <TextBlock Text="No personally identifiable information beyond your external IP address is collected."
                                                       FontSize="12" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,12"/>

                                            <CheckBox x:Name="chk_TelemetryOptOut"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      Content="Opt-in for anonymous telemetry"
                                                      IsChecked="False"/>

                                            <!-- GUID panel: shown when opted in -->
                                            <Border x:Name="panel_TelemetryGuid" Visibility="Collapsed"
                                                    Background="{DynamicResource InputBackground}"
                                                    BorderBrush="{DynamicResource InputBorder}"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="12,10" Margin="0,12,0,0">
                                                <StackPanel>
                                                    <TextBlock FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4">
                                                        <Run Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Your Telemetry ID"/>
                                                    </TextBlock>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock x:Name="txt_TelemetryGuid"
                                                                   Grid.Column="0"
                                                                   FontSize="12" FontFamily="Cascadia Code,Consolas,monospace"
                                                                   Foreground="{DynamicResource WindowForeground}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <Button x:Name="btn_CopyTelemetryGuid" Grid.Column="1"
                                                                Style="{StaticResource SecondaryButton}"
                                                                Height="28" Padding="10,4" Margin="8,0,0,0" ToolTip="Copy to clipboard">
                                                            <TextBlock FontSize="11"><Run Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Copy"/></TextBlock>
                                                        </Button>
                                                    </Grid>
                                                    <TextBlock Text="Use this ID when submitting feedback or reporting issues to the developer."
                                                               FontSize="11" TextWrapping="Wrap"
                                                               Foreground="{DynamicResource InputPlaceholder}" Margin="0,6,0,0"/>
                                                    <Grid Margin="0,10,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Button x:Name="btn_TestTelemetry" Grid.Column="0"
                                                                Style="{StaticResource SecondaryButton}"
                                                                Height="32" Padding="12,4" ToolTip="Test connectivity to the telemetry API">
                                                            <TextBlock FontSize="11" VerticalAlignment="Center"><Run Text="&#xE968;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Test Telemetry"/></TextBlock>
                                                        </Button>
                                                        <TextBlock x:Name="txt_TelemetryTestResult" Grid.Column="1"
                                                                   FontSize="11" VerticalAlignment="Center"
                                                                   Margin="10,0,0,0" TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource InputPlaceholder}"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Teams Notifications -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,12">
                                                <Run Text="&#xE715;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Teams Notifications"/>
                                            </TextBlock>
                                            <TextBlock Text="Receive build completion notifications in Microsoft Teams via webhook."
                                                       Foreground="{DynamicResource InputPlaceholder}" FontSize="12"
                                                       TextWrapping="Wrap" Margin="0,0,0,12"/>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox x:Name="chk_TeamsNotifications" Grid.Column="0"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,8,0"/>
                                                <TextBlock Grid.Column="1" Text="Enable Teams Notifications"
                                                           FontSize="12" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource WindowForeground}"/>
                                            </Grid>

                                            <TextBlock Text="Webhook URL" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,8,0,6"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="txt_TeamsWebhookUrl"
                                                         Style="{StaticResource RoundedTextBox}"
                                                         Height="36"/>
                                                <Button x:Name="btn_TeamsTest" Grid.Column="1"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Height="34" Margin="8,0,0,0">
                                                    <TextBlock><Run Text="&#xE724;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Test"/></TextBlock>
                                                </Button>
                                            </Grid>
                                            <TextBlock x:Name="txt_TeamsTestResult"
                                                       FontSize="11" Margin="0,4,0,0"
                                                       Foreground="{DynamicResource InputPlaceholder}"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Backup / Restore Options -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,12">
                                                <Run Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="14"/><Run Text="  Backup / Restore Options"/>
                                            </TextBlock>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="btn_ExportConfig"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Height="34" Margin="0,0,8,0">
                                                    <TextBlock><Run Text="&#xEDE1;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Export Config"/></TextBlock>
                                                </Button>
                                                <Button x:Name="btn_ImportConfig" Grid.Column="1"
                                                        Style="{StaticResource SecondaryButton}" Height="34">
                                                    <TextBlock><Run Text="&#xE8B5;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Import Config"/></TextBlock>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- View: Log Viewer -->
                        <Grid x:Name="view_Log" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}">
                                <Run Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="20"/><Run Text="  View Extended Log"/>
                            </TextBlock>

                            <Grid Grid.Row="1" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="btn_OpenLogFile" Grid.Column="0"
                                        Style="{StaticResource SecondaryButton}" Height="34">
                                    <TextBlock><Run Text="&#xED25;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Open in CMTrace"/></TextBlock>
                                </Button>
                                <Button x:Name="btn_RefreshLog" Grid.Column="1"
                                        Style="{StaticResource SecondaryButton}" Height="34" Margin="8,0,0,0">
                                    <TextBlock><Run Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Refresh"/></TextBlock>
                                </Button>
                                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="txt_LogStats" FontSize="11"
                                               Foreground="{DynamicResource InputPlaceholder}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="2" CornerRadius="10"
                                    BorderBrush="{DynamicResource SidebarActive}"
                                    BorderThickness="1"
                                    Background="{DynamicResource SidebarBackground}"
                                    ClipToBounds="True">
                                <Grid>
                                    <!-- Column Headers -->
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource SidebarActive}"
                                            Padding="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SidebarForeground}" Padding="8,8"/>
                                            <TextBlock Grid.Column="1" Text="Time" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SidebarForeground}" Padding="8,8"/>
                                            <TextBlock Grid.Column="2" Text="Date" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SidebarForeground}" Padding="8,8"/>
                                            <TextBlock Grid.Column="3" Text="Message" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SidebarForeground}" Padding="8,8"/>
                                        </Grid>
                                    </Border>
                                    <ListBox x:Name="lst_LogEntries" Grid.Row="1"
                                             Background="{DynamicResource SidebarBackground}"
                                             BorderThickness="0"
                                             VirtualizingStackPanel.IsVirtualizing="True"
                                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Visible">
                                        <ListBox.Resources>
                                            <Style TargetType="ScrollBar">
                                                <Style.Triggers>
                                                    <Trigger Property="Orientation" Value="Vertical">
                                                        <Setter Property="Template" Value="{StaticResource WideVerticalScrollBar}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.Resources>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- View: Custom Driver Pack -->
                        <Grid x:Name="view_CustomDriverPack" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}">
                                <Run Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="20"/><Run Text="  Custom Driver Pack"/>
                            </TextBlock>

                            <ScrollViewer x:Name="scroll_CustomDriverPack" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>

                                    <!-- Description -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,8">
                                                <Run Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  About Custom Driver Packs"/>
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="13"
                                                       Foreground="{DynamicResource InputPlaceholder}" LineHeight="20">
                                                Create a driver package from the currently installed drivers on this device using PNPUtil,
                                                or from a local folder containing driver INF files.
                                                The device Make, Model, and BaseBoard Product are automatically detected via WMI but can be
                                                overridden. Exported drivers are packaged for the selected platform (ConfigMgr or Intune).
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Device Information -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,8">
                                                <Run Text="&#xE7F7;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Device Information"/>
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,16" LineHeight="20">
