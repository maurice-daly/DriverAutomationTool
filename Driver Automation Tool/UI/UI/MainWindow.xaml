                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,12">
                                            <Run Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  By Manufacturer"/>
                                        </TextBlock>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Viewbox Grid.Column="0" Width="120" Height="120" Margin="0,0,24,0">
                                                <Canvas Width="120" Height="120">
                                                    <Ellipse Width="100" Height="100" Canvas.Left="10" Canvas.Top="10"
                                                             Stroke="{DynamicResource SidebarActive}" StrokeThickness="16" Fill="Transparent"/>
                                                    <Path x:Name="arc_Mfr_Dell" Stroke="#3B82F6" StrokeThickness="16"
                                                          StrokeStartLineCap="Flat" StrokeEndLineCap="Flat" Fill="Transparent"/>
                                                    <Path x:Name="arc_Mfr_HP" Stroke="#10B981" StrokeThickness="16"
                                                          StrokeStartLineCap="Flat" StrokeEndLineCap="Flat" Fill="Transparent"/>
                                                    <Path x:Name="arc_Mfr_Lenovo" Stroke="#F59E0B" StrokeThickness="16"
                                                          StrokeStartLineCap="Flat" StrokeEndLineCap="Flat" Fill="Transparent"/>
                                                    <Path x:Name="arc_Mfr_Microsoft" Stroke="#8B5CF6" StrokeThickness="16"
                                                          StrokeStartLineCap="Flat" StrokeEndLineCap="Flat" Fill="Transparent"/>
                                                    <Path x:Name="arc_Mfr_Acer" Stroke="#EF4444" StrokeThickness="16"
