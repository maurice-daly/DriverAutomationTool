                        <!-- View: Modern Driver/BIOS Management -->
                        <Grid x:Name="view_ModernMgmt" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}">
                                <Run Text="&#xECAD;" FontFamily="Segoe MDL2 Assets" FontSize="20"/><Run Text="  Modern Driver/BIOS Management"/>
                            </TextBlock>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="0,8,0,0">

                                    <TextBlock TextWrapping="Wrap" FontSize="13"
                                               Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,16">
                                        The Driver Automation Tool is a key component of the Modern Driver Management and Modern BIOS Management solutions from MSEndpointMgr. These solutions extend Configuration Manager (ConfigMgr) with fully automated, dynamic driver and BIOS update workflows during OS deployment.
                                    </TextBlock>

                                    <!-- Modern Driver Management -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Modern Driver Management" FontSize="18" FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentColor}" Margin="0,0,0,8"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="13"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,12">
                                                Modern Driver Management automates driver package selection and installation during OS deployment. It combines the Driver Automation Tool (to download and create driver packages), the ConfigMgr AdminService (for dynamic package queries), and the Apply Driver Package script (Invoke-CMApplyDriverPackage.ps1) which runs inside your task sequence to automatically match the correct driver package to the device being deployed.
                                            </TextBlock>

                                            <TextBlock Text="How It Works" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                                            <StackPanel Margin="8,0,0,12">
                                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                    <Run FontWeight="SemiBold" Text="1. Create Packages"/> — Use the Driver Automation Tool to download and create ConfigMgr Standard Packages for each model. Distribute content to your distribution points.
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                    <Run FontWeight="SemiBold" Text="2. Configure AdminService"/> — Set up a service account with Read-Only Analyst permissions in ConfigMgr. The AdminService REST API provides the interface for dynamic package lookup.
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                    <Run FontWeight="SemiBold" Text="3. Task Sequence Integration"/> — Add a "Set Dynamic Variables" step to store authentication values, then a "Run PowerShell Script" step invoking Invoke-CMApplyDriverPackage.ps1. The script auto-detects manufacturer, model, and SKU to find the matching driver package.
                                                </TextBlock>
                                            </StackPanel>

                                            <TextBlock Text="Supported Scenarios" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                                            <StackPanel Margin="8,0,0,12">
                                                <TextBlock FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,3" Text="&#x2022;  Bare Metal OS Deployment"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,3" Text="&#x2022;  OS Upgrade Task Sequences"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,3" Text="&#x2022;  Driver Update Maintenance"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,3" Text="&#x2022;  Pre-Caching Driver Packages"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,3" Text="&#x2022;  Cloud Management Gateway (select scenarios)"/>
                                            </StackPanel>

                                            <Button x:Name="btn_MDMLink" Style="{StaticResource RoundedButton}" HorizontalAlignment="Left" Height="34" Margin="0,0,0,0" Cursor="Hand">
                                                <TextBlock><Run Text="&#xE71B;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Learn More — Modern Driver Management"/></TextBlock>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <!-- Modern BIOS Management -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Modern BIOS Management" FontSize="18" FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentColor}" Margin="0,0,0,8"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="13"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,12">
                                                Modern BIOS Management provides a dynamic solution for maintaining and deploying BIOS updates via ConfigMgr task sequences. It uses the Driver Automation Tool to create BIOS update packages, the ConfigMgr WebService or AdminService for package queries, and manufacturer-specific scripts to apply updates during OS deployment or scheduled BIOS maintenance.
                                            </TextBlock>

                                            <TextBlock Text="How It Works" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                                            <StackPanel Margin="8,0,0,12">
                                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                    <Run FontWeight="SemiBold" Text="1. Create BIOS Packages"/> — In the Driver Automation Tool, select ConfigMgr Standard Pkg as the deployment platform, choose BIOS as the download type, then select your models and build packages.
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                    <Run FontWeight="SemiBold" Text="2. Download BIOS Script"/> — The Invoke-CMDownloadBIOSPackage.ps1 script detects manufacturer, SystemSKU, OS version, and architecture to match the correct BIOS package. A task sequence variable (NewBIOSAvailable) is set to True when an update is found.
                                                </TextBlock>
                                                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,4">
                                                    <Run FontWeight="SemiBold" Text="3. Apply BIOS Update"/> — Manufacturer-specific scripts (Invoke-DellBIOSUpdate.ps1, Invoke-HPBIOSUpdate.ps1, Invoke-LenovoBIOSUpdate.ps1, Invoke-MicrosoftBIOSUpdate.ps1) handle the actual BIOS flash process within the task sequence.
                                                </TextBlock>
                                            </StackPanel>

                                            <TextBlock Text="Manufacturer Scripts" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                                            <StackPanel Margin="8,0,0,12">
                                                <TextBlock FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,3" Text="&#x2022;  Invoke-CMDownloadBIOSPackage.ps1 — Dynamic BIOS package matching"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,3" Text="&#x2022;  Invoke-DellBIOSUpdate.ps1 — Dell BIOS update handler"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,3" Text="&#x2022;  Invoke-HPBIOSUpdate.ps1 — HP BIOS update handler"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,3" Text="&#x2022;  Invoke-LenovoBIOSUpdate.ps1 — Lenovo BIOS update handler"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,3" Text="&#x2022;  Invoke-MicrosoftBIOSUpdate.ps1 — Microsoft Surface BIOS update handler"/>
                                            </StackPanel>

                                            <Button x:Name="btn_MBMLink" Style="{StaticResource RoundedButton}" HorizontalAlignment="Left" Height="34" Margin="0,0,0,0" Cursor="Hand">
                                                <TextBlock><Run Text="&#xE71B;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Learn More — Modern BIOS Management"/></TextBlock>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <!-- GitHub Resources -->
                                    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="GitHub Resources" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,8"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Button x:Name="btn_MDMGitHub" Style="{StaticResource RoundedButton}" HorizontalAlignment="Left" Height="34" Margin="0,0,8,0" Cursor="Hand">
                                                    <TextBlock><Run Text="&#xE71B;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Modern Driver Management"/></TextBlock>
                                                </Button>
                                                <Button x:Name="btn_MBMGitHub" Style="{StaticResource RoundedButton}" HorizontalAlignment="Left" Height="34" Margin="0,0,0,0" Cursor="Hand">
                                                    <TextBlock><Run Text="&#xE71B;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Modern BIOS Management"/></TextBlock>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

