                        <!-- View: Distribution Points -->
                        <Grid x:Name="view_Distribution" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}">
                                <Run Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="20"/><Run Text="  Distribution Points"/>
                            </TextBlock>

                            <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,8">
                                        <Run Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Replication Priority"/>
                                    </TextBlock>
                                    <TextBlock TextWrapping="Wrap" FontSize="12"
                                               Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,16" LineHeight="20">
                                        Controls the order in which Configuration Manager distributes content to distribution points. Packages assigned a higher priority are sent before those with a lower priority, helping ensure critical content reaches endpoints first when bandwidth is constrained.
                                    </TextBlock>

                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Left column: Replication Priority -->
                                        <DockPanel Grid.Column="0" LastChildFill="False">
                                            <TextBlock DockPanel.Dock="Top" Text="Distribution Point Replication Priority" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,8"/>
                                            <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" FontSize="12"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4" LineHeight="20">
                                                Configure delivery schedules and rate limits per distribution point.
                                            </TextBlock>
                                            <TextBlock DockPanel.Dock="Top" FontSize="12" Margin="0,0,0,12">
                                                <Hyperlink x:Name="link_DPScheduling"
                                                           NavigateUri="https://learn.microsoft.com/en-us/intune/configmgr/core/servers/deploy/configure/install-and-configure-distribution-points#bkmk_config-sched"
                                                           Foreground="{DynamicResource AccentColor}">Distribution Point Scheduling</Hyperlink>
                                            </TextBlock>
                                            <ComboBox x:Name="cmb_DistPriority" DockPanel.Dock="Bottom" Height="34" Width="Auto" MinWidth="110"
                                                      HorizontalAlignment="Left" VerticalAlignment="Bottom">
                                                <ComboBoxItem Content="High"/>
                                                <ComboBoxItem Content="Normal" IsSelected="True"/>
                                                <ComboBoxItem Content="Low"/>
                                            </ComboBox>
                                        </DockPanel>

                                        <!-- Right column: Binary Differential Replication -->
                                        <DockPanel Grid.Column="2" LastChildFill="False">
                                            <TextBlock DockPanel.Dock="Top" Text="Binary Differential Replication" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,8"/>
                                            <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" FontSize="12"
                                                       Foreground="{DynamicResource InputPlaceholder}" Margin="0,0,0,4" LineHeight="20">
                                                Transmits only changed binary blocks rather than entire files, reducing bandwidth during content updates.
                                            </TextBlock>
                                            <TextBlock DockPanel.Dock="Top" FontSize="12" Margin="0,0,0,12">
                                                <Hyperlink x:Name="link_ContentManagement"
                                                           NavigateUri="https://learn.microsoft.com/en-us/intune/configmgr/core/plan-design/hierarchy/fundamental-concepts-for-content-management"
                                                           Foreground="{DynamicResource AccentColor}">Content Management Concepts</Hyperlink>
                                            </TextBlock>
                                            <Grid DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox x:Name="chk_BinaryDiffReplication"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,12,0"/>
                                                <TextBlock x:Name="txt_BdrState" Grid.Column="1"
                                                           Text="Off" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource InputPlaceholder}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </DockPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Style="{StaticResource CardPanel}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,8">
                                        <Run Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Distribution Point Groups"/>
                                    </TextBlock>
                                    <DataGrid x:Name="grid_DPGroups" Grid.Row="1" Style="{StaticResource ModernDataGrid}">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="&#x2611;" Width="40" CanUserSort="False">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding Selected, UpdateSourceTrigger=PropertyChanged}"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Group Name" Width="*" Binding="{Binding Name}" IsReadOnly="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Border Grid.Row="3" Style="{StaticResource CardPanel}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,8">
                                        <Run Text="&#xE753;" FontFamily="Segoe MDL2 Assets" FontSize="13"/><Run Text="  Distribution Points"/>
                                    </TextBlock>
                                    <DataGrid x:Name="grid_DPs" Grid.Row="1" Style="{StaticResource ModernDataGrid}">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="&#x2611;" Width="40" CanUserSort="False">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding Selected, UpdateSourceTrigger=PropertyChanged}"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="Server Name" Width="*" Binding="{Binding Name}" IsReadOnly="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- View: Intune Settings -->
                        <Grid x:Name="view_IntuneSettings" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
