                        </Grid>

                    </Grid>
                </Border>
            </Grid>

            <!-- Schedule Build Modal Overlay -->
            <Grid x:Name="overlay_Schedule" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed">
                <Border Background="#80000000"/>
                <Border Background="{DynamicResource WindowBackground}"
                        BorderBrush="{DynamicResource WindowBorder}" BorderThickness="1"
                        CornerRadius="{StaticResource CardRadius}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="460" Padding="28">
                    <StackPanel>
                        <TextBlock Text="Schedule Automated Build" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,16"/>
                        <TextBlock Text="Configure a scheduled task to run unattended package builds."
                                   Foreground="{DynamicResource InputPlaceholder}" TextWrapping="Wrap"
                                   FontSize="12" Margin="0,0,0,20"/>

                        <!-- Frequency -->
                        <TextBlock Text="Frequency" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cmb_ScheduleFrequency"
                                  Height="36" Margin="0,0,0,12">
                            <ComboBoxItem Content="Once Off"/>
                            <ComboBoxItem Content="Daily" IsSelected="True"/>
                            <ComboBoxItem Content="Weekly"/>
                        </ComboBox>

                        <!-- Day of Week (visible for Weekly) -->
                        <StackPanel x:Name="panel_ScheduleDay" Visibility="Collapsed">
                            <TextBlock Text="Day of Week" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                            <ComboBox x:Name="cmb_ScheduleDay"
                                      Height="36" Margin="0,0,0,12">
                                <ComboBoxItem Content="Monday" IsSelected="True"/>
                                <ComboBoxItem Content="Tuesday"/>
                                <ComboBoxItem Content="Wednesday"/>
                                <ComboBoxItem Content="Thursday"/>
                                <ComboBoxItem Content="Friday"/>
                                <ComboBoxItem Content="Saturday"/>
                                <ComboBoxItem Content="Sunday"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Time -->
                        <TextBlock Text="Time (24h)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="cmb_ScheduleHour" Grid.Column="0" Height="36">
                                <ComboBoxItem Content="00"/><ComboBoxItem Content="01"/>
                                <ComboBoxItem Content="02" IsSelected="True"/><ComboBoxItem Content="03"/>
                                <ComboBoxItem Content="04"/><ComboBoxItem Content="05"/>
                                <ComboBoxItem Content="06"/><ComboBoxItem Content="07"/>
                                <ComboBoxItem Content="08"/><ComboBoxItem Content="09"/>
                                <ComboBoxItem Content="10"/><ComboBoxItem Content="11"/>
                                <ComboBoxItem Content="12"/><ComboBoxItem Content="13"/>
                                <ComboBoxItem Content="14"/><ComboBoxItem Content="15"/>
                                <ComboBoxItem Content="16"/><ComboBoxItem Content="17"/>
                                <ComboBoxItem Content="18"/><ComboBoxItem Content="19"/>
                                <ComboBoxItem Content="20"/><ComboBoxItem Content="21"/>
                                <ComboBoxItem Content="22"/><ComboBoxItem Content="23"/>
                            </ComboBox>
                            <TextBlock Grid.Column="1" Text=":" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource WindowForeground}"
                                       VerticalAlignment="Center" Margin="8,0,8,0"/>
                            <ComboBox x:Name="cmb_ScheduleMinute" Grid.Column="2" Height="36">
                                <ComboBoxItem Content="00" IsSelected="True"/><ComboBoxItem Content="05"/>
                                <ComboBoxItem Content="10"/><ComboBoxItem Content="15"/>
                                <ComboBoxItem Content="20"/><ComboBoxItem Content="25"/>
                                <ComboBoxItem Content="30"/><ComboBoxItem Content="35"/>
                                <ComboBoxItem Content="40"/><ComboBoxItem Content="45"/>
                                <ComboBoxItem Content="50"/><ComboBoxItem Content="55"/>
                            </ComboBox>
                        </Grid>

                        <!-- Config Path -->
                        <TextBlock Text="Build Config" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WindowForeground}" Margin="0,0,0,6"/>
                        <TextBox x:Name="txt_ScheduleConfigPath"
                                 Style="{StaticResource RoundedTextBox}"
                                 IsReadOnly="True" Height="36" Margin="0,0,0,4"/>
                        <TextBlock Text="Uses Settings\BuildConfig.json by default."
                                   Foreground="{DynamicResource InputPlaceholder}"
                                   FontSize="11" Margin="0,0,0,16"/>

                        <!-- Info banner -->
                        <Border Background="{DynamicResource ProgressBackground}" CornerRadius="6"
                                Padding="12,8" Margin="0,0,0,20">
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{DynamicResource WindowForeground}">
                                <Run FontWeight="SemiBold" Text="Note:"/>
                                <Run Text="The scheduled task runs as SYSTEM with elevated privileges. Models from Settings\BuildConfig.json will be used."/>
                            </TextBlock>
                        </Border>

                        <!-- Buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btn_ScheduleRemove" Grid.Column="1"
                                    Style="{StaticResource DangerButton}"
                                    Height="34" Margin="0,0,8,0" Visibility="Collapsed">
                                <TextBlock><Run Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Remove"/></TextBlock>
                            </Button>
                            <Button x:Name="btn_ScheduleSave" Grid.Column="2"
                                    Style="{StaticResource RoundedButton}"
                                    Height="34" Margin="0,0,8,0">
                                <TextBlock><Run Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Save"/></TextBlock>
                            </Button>
                            <Button x:Name="btn_ScheduleCancel" Grid.Column="3"
                                    Style="{StaticResource RoundedButton}"
                                    Height="34">
                                <TextBlock><Run Text="&#xE711;" FontFamily="Segoe MDL2 Assets"/><Run Text="  Cancel"/></TextBlock>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

        </Grid>

    </Border>
</Window>
