                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                    <Border Width="14" Height="14" CornerRadius="3" Background="#F59E0B" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="BIOS Updates" FontSize="13" Foreground="{DynamicResource WindowForeground}" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="txt_ChartBiosCount" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource WindowForeground}" Margin="8,0,0,0" VerticalAlignment="Center" Text="0"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="14" Height="14" CornerRadius="3" Background="#6B7280" Margin="0,0,10,0" VerticalAlignment="Center"/>
