                                                        <ColumnDefinition Width="24"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="4." FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentColor}"/>
